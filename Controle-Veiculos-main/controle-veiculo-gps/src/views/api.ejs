<div class="m-4">
    <div class="card">
        <div class="card-header">
            <h2>
                <i class="fas fa-code"></i>
                Endpoints
            </h2>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="thead-dark">
                        <tr>
                            <th nowrap><i class="fas fa-link"></i> Endpoint</th>
                            <th nowrap><i class="fas fa-info-circle"></i> Descrição</th>
                            <th width="1" nowrap><i class="fas fa-user-lock"></i> Autenticação?</th>
                            <th width="1" nowrap><i class="fas fa-code"></i> Handler</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% endpoints.forEach(endpoint => { %>
                        <tr>
                            <td nowrap>
                                <a href="<%= endpoint.path %>" target="_blank" class="text-decoration-none">
                                    <span class="badge <% if (endpoint.requiresAuth) { %>bg-primary shadow<% } else { %>bg-success shadow<% } %>">
                                        <i class="fas <%= endpoint.icon %> me-1"></i>
                                        <%= endpoint.path %>
                                    </span>
                                </a>
                            </td>
                            <td><%= endpoint.description || 'sem descrição' %></td>
                            <td>
                                <% if (endpoint.requiresAuth) { %>
                                <span class="badge badge-danger">Yes</span>
                                <% } else { %>
                                <span class="badge badge-success">No</span>
                                <% } %>
                            </td>
                            <td><%= endpoint.handler %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
