        <script>
            const storage = {
                get: name => {
                    try {
                        // Try cookies first
                        let value = Cookies.get(name);
                        if (value !== undefined) return value;

                        // Try localStorage with JSON parsing
                        value = localStorage.getItem(name);
                        if (value !== null) {
                            try {
                                return JSON.parse(value);
                            } catch {
                                return value;
                            }
                        }

                        // Try sessionStorage as fallback
                        value = sessionStorage.getItem(name);
                        if (value !== null) {
                            try {
                                return JSON.parse(value);
                            } catch {
                                return value;
                            }
                        }

                        return undefined;
                    } catch (e) {
                        console.error('Storage read error:', e);
                        return undefined;
                    }
                },
                set: (name, value) => {
                    try {
                        if (typeof value === 'string') {
                            localStorage.setItem(name, value);
                            sessionStorage.setItem(name, value);
                        } else {
                            const jsonValue = JSON.stringify(value);
                            localStorage.setItem(name, jsonValue);
                            sessionStorage.setItem(name, jsonValue);
                        }
                    } catch (e) {
                        console.error('Storage write error:', e);
                    }
                },
            };
            function showToast(message, type = 'danger') {
                console.log(message);
                let toastId = 'toast-' + Date.now();
                let toastHTML = `
          <div id="${toastId}" class="toast align-items-center text-bg-${type} border-0" role="alert"
               aria-live="assertive" aria-atomic="true">
              <div class="d-flex">
                  <div class="toast-body">
                      ${message}
                  </div>
                  <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Fechar"></button>
              </div>
          </div>
        `;
                let container = $('#toast-container');
                if (!container.length) {
                    container = $('<div id="toast-container" class="toast-container position-fixed top-0 end-0 p-3"></div>');
                    $('body').append(container);
                }
                container.append(toastHTML);
                const toastEl = document.getElementById(toastId);
                const toast = new bootstrap.Toast(toastEl, { delay: 5000 });
                toast.show();
            }
            function warning(message) {
                showToast(message, 'warning');
            }
            function error(message) {
                showToast(message, 'danger');
            }
            function success(message) {
                showToast(message, 'success');
            }
            function info(message) {
                showToast(message, 'info');
            }
            function debug(message) {
                showToast(message, 'dark');
            }
            function danger(message) {
                showToast(message, 'danger');
            }
            const get = (name, default_value) => {
                let value = localStorage.getItem(name);
                if (value === null) {
                    console.log(`set ${name} default_value ${value}`);
                    return default_value;
                }
                console.log(`get from localStorage ${name}=${value}`);
                return value;
            };
            const set = (name, value) => {
                localStorage.setItem(name, value);
                console.log(`set to localStorage ${name}=${value}`);
            };
            class Socket {
                socket;
                constructor() {
                    this.socket = io();
                    this.socket.on('connect', this.on_connect.bind(this));
                    this.socket.on('disconnect', this.on_disconnect.bind(this));
                    this.socket.on('reconnect_attempt', this.on_reconnect_attempt.bind(this));
                    this.socket.on('reconnect', this.on_reconnect.bind(this));
                    this.socket.on('disconnect', this.on_disconnect.bind(this));
                    this.socket.on('reconnect_attempt', this.on_reconnect_attempt.bind(this));
                    this.socket.on('reconnect', this.on_reconnect.bind(this));
                    this.socket.on('debug', this.on_debug.bind(this));
                }
                on_connect() {
                    console.log('connected');
                    const initCallbackName = '<%- init %>';
                    if (initCallbackName) console.log(`initCallback:`, initCallbackName);
                    if (initCallbackName && typeof window[initCallbackName] === 'function') {
                        $(document).ready(() => {
                            window[initCallbackName]();
                        });
                    } else if (initCallbackName && typeof window[initCallbackName] !== 'function') {
                        console.log(`initCallback: ${initCallbackName} is not a function`);
                    }
                }
                on_disconnect() {
                    console.log('disconnected');
                }
                on_reconnect_attempt() {
                    console.log('reconnected');
                }
                on_reconnect() {
                    console.log('reconnected');
                }
                on_debug(data) {
                    console.log('debug', data);
                }
                send(route_id, data) {
                    //console.log('send', route_id, data)
                    this.socket.emit(route_id, data);
                }
                on(event, callback) {
                    //console.log('on', event)
                    this.socket.on(event, callback);
                }
            }
            const bytesToSize = bytes => {
                const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
                if (bytes === 0) return '0 B';
                const i = Math.floor(Math.log(bytes) / Math.log(1024));
                return Math.round(bytes / Math.pow(1024, i), 2) + ' ' + sizes[i];
            };
            const send = (route_id, data) => fd.send(route_id, data);
            let is_dark;
            const is_tablet = window.matchMedia && window.matchMedia('(max-width: 768px)').matches;
            const is_mobile = window.matchMedia && window.matchMedia('(max-width: 480px)').matches;
            const is_desktop = window.matchMedia && window.matchMedia('(min-width: 768px)').matches;
            const set_theme = () => {
                is_dark = get('is_dark', window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches);
                console.log('is_dark', is_dark);
                if (is_dark === 'true' || is_dark === true) {
                    document.documentElement.setAttribute('data-bs-theme', 'dark');
                    $('body').addClass('dark-bg-gradient').removeClass('light-bg-gradient');
                    $('.navbar').addClass('navbar-dark ').removeClass('navbar-light bg-light');
                    $('#dark-icon').hide();
                    $('#light-icon').show();
                } else {
                    document.documentElement.setAttribute('data-bs-theme', 'light');
                    $('body').addClass('light-bg-gradient').removeClass('dark-bg-gradient');
                    $('.navbar').addClass('navbar-light ').removeClass('navbar-dark bg-dark');
                    $('#dark-icon').show();
                    $('#light-icon').hide();
                }
                $('#theme-toggle').on('click', function () {
                    const current = document.documentElement.getAttribute('data-bs-theme');
                    const new_theme_is_light = current === 'dark' ? 'false' : 'true';
                    console.log({ current, new_theme_is_light });
                    set('is_dark', new_theme_is_light);
                    location.reload();
                });
            };
            let fd;
            $(document).ready(() => {
                set_theme();
                //fd = new Socket();
            });
        </script>
        <style>
            [data-bs-theme='light'] .bg-gradient {
