<%
// manutencao-detalhe.ejs
// Variáveis esperadas: manut (obj), arquivos (array), csrfToken, user
function fmtDateTime(d) {
  if (!d) return '';
  if (typeof d === 'string') return d;
  if (d instanceof Date) return d.toISOString().slice(0,16).replace('T',' ');
  try { return String(d); } catch(e) { return ''; }
}
%>

<div class="container-fluid my-4">
  <div class="row">
    <div class="col-lg-9">
      <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-start">
          <div>
            <h5 class="mb-0">Manutenção — ID: <%= manut.id %></h5>
            <small class="text-muted">
              Veículo: <%= manut.veiculo_nome || manut.veiculo_id %>
              <% if (manut.placa) { %> — Placa: <%= manut.placa %><% } %>
              <% if (manut.criado_em) { %> — Criado em: <%= manut.criado_em %><% } %>
            </small>
          </div>

          <div class="d-flex gap-2">
            <!-- <button type="button"href="/manutencoes" class="btn btn-sm btn-outline-secondary">Voltar</button> -->
             <button type="button" id="btnVoltar" class="btn btn-sm btn-outline-secondary">Voltar</button>
            <!--<button type="button" href="/manutencoes/<%= manut.id %>/edit" class="btn btn-sm btn-primary">Editar manutenção</button> -->
            <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#confirmDeleteModal">Excluir</button>
          </div>
        </div>

        <div class="card-body">
          <dl class="row">
            <dt class="col-sm-3">Tipo</dt>
            <dd class="col-sm-9"><%= manut.tipo %></dd>

            <dt class="col-sm-3">Descrição</dt>
            <dd class="col-sm-9"><pre style="white-space:pre-wrap" class="mb-0"><%= manut.descricao || '-' %></pre></dd>

            <dt class="col-sm-3">KM agendado</dt>
            <dd class="col-sm-9"><%= manut.km_agendado || '-' %></dd>

            <dt class="col-sm-3">Data agendada</dt>
            <dd class="col-sm-9"><%= manut.data_agendada || '-' %></dd>

            <dt class="col-sm-3">Data realizada</dt>
            <dd class="col-sm-9"><%= manut.data_realizada || '-' %></dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
              <% if (manut.status === 'pendente') { %>
                <span class="badge bg-warning text-dark">Pendente</span>
              <% } else if (manut.status === 'em_manutencao') { %>
                <span class="badge bg-info text-dark">Em manutenção</span>
              <% } else if (manut.status === 'realizada') { %>
                <span class="badge bg-success">Realizada</span>
              <% } else if (manut.status === 'cancelada') { %>
                <span class="badge bg-danger">Cancelada</span>
              <% } else { %>
                <span class="badge bg-secondary"><%= manut.status %></span>
              <% } %>
            </dd>
          </dl>

          <hr>

          <!-- Upload de anexos -->
          <form id="uploadForm" action="/manutencoes/<%= manut.id %>/upload" method="post" enctype="multipart/form-data" class="mb-4">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="row g-2 align-items-center">
              <div class="col-auto">
                <input type="file" id="fotosUpload" name="fotos" class="form-control" multiple accept="image/*,application/pdf">
              </div>
              <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-outline-primary">Enviar anexos</button>
              </div>
              <div class="col-auto">
                <small class="text-muted">Aceita imagens e PDFs</small>
              </div>
            </div>
          </form>

          <h6>Anexos</h6>
          <% if (!arquivos || arquivos.length === 0) { %>
            <p class="text-muted">Nenhum anexo cadastrado.</p>
          <% } else { %>
            <div class="row g-3">
              <% arquivos.forEach(function(a) {
                   var safeName = (a.original_name || '').replace(/'/g, '&#39;');
              %>
                <div class="col-md-6">
                  <div class="card h-100">
                    <div class="card-body d-flex flex-column">
                      <div class="d-flex justify-content-between align-items-start">
                        <div>
                          <div class="fw-semibold"><%= a.original_name %></div>
                          <small class="text-muted"><%= a.mime %> • <%= Math.round(a.size/1024) %> KB • <%= a.criado_em %></small>
                        </div>
                        <div class="text-end">
                          <% if (a.mime && a.mime.indexOf('image/') === 0) { %>
                            <a href="/manutencoes/arquivo/<%= a.id %>/download" target="_blank" class="btn btn-sm btn-outline-primary mb-2">Visualizar</a>
                          <% } else { %>
                            <a href="/manutencoes/arquivo/<%= a.id %>/download" class="btn btn-sm btn-outline-primary mb-2">Baixar</a>
                          <% } %>

                          <form action="/manutencoes/<%= manut.id %>/arquivo/<%= a.id %>/delete" method="post" onsubmit="return confirm('Remover anexo: <%= safeName %>?')">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Excluir anexo</button>
                          </form>
                        </div>
                      </div>

                      <% if (a.mime && a.mime.indexOf('image/') === 0) { %>
                        <div class="mt-3">
                          <img src="/manutencoes/arquivo/<%= a.id %>/download" alt="<%= a.original_name %>" class="img-fluid rounded" style="max-height:180px; object-fit:contain;">
                        </div>
                      <% } %>
                    </div>
                  </div>
                </div>
              <% }); %>
            </div>
          <% } %>

        </div> <!-- card-body -->
      </div> <!-- card -->
    </div>
  </div>
</div>

<!-- Modal excluir manutenção -->
<form id="deleteMaintenanceForm" action="/manutencoes/<%= manut.id %>/delete" method="post" class="d-none">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
</form>

<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-labelledby="confirmDeleteLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="confirmDeleteLabel">Confirmar exclusão</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
      </div>
      <div class="modal-body">
        Tem certeza que deseja excluir a manutenção ID: <strong><%= manut.id %></strong>? Esta ação removerá também os anexos relacionados.
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-danger" onclick="document.getElementById('deleteMaintenanceForm').submit();">Excluir</button>
      </div>
    </div>
  </div>
</div>

<script>
  document.getElementById('fotosUpload')?.addEventListener('change', function() {
    if (this.files && this.files.length > 30) alert('Você selecionou muitos arquivos. O limite recomendado é 30 por upload.');
  });
</script>

<script>
  document.getElementById('btnVoltar').addEventListener('click', function () {
    // 1) Navega para /manutencoes e adiciona um parâmetro único para forçar reload do servidor
    //    Use window.location.replace se não quiser empurrar um novo histórico no browser.
    window.location.href = '/manutencoes?_=' + Date.now();

    // Alternativa (substitua a linha acima por esta se preferir não adicionar histórico):
    // window.location.replace('/manutencoes?_=' + Date.now());
  });
</script>
