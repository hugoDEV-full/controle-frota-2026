<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>
    <%= title %>
  </title>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <!-- Font Awesome -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

  <!-- Leaflet CSS -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.fullscreen/1.6.0/Control.FullScreen.css" />

  <style>
    .vehicle-marker-icon i {
      color: #1978c8;
      text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.4);
    }
  </style>

  <style>
    #map {
      width: 94%;
      height: 500px;
      border-radius: 10px;
      margin: 20px auto;
      /* 20px em cima e embaixo, auto nas laterais */
    }


    /* Estilização do menu lateral */
    #vehicle-menu {
      position: absolute;
      top: 50px;
      right: 10px;
      background: rgba(255, 255, 255, 0.9);
      padding: 10px;
      width: 200px;
      max-height: 400px;
      overflow-y: auto;
      border-radius: 5px;
      box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.3);
    }

    #vehicle-menu h4 {
      margin-top: 0;
    }

    .vehicle-item {
      padding: 5px;
      border-bottom: 1px solid #ccc;
      cursor: pointer;
    }

    .vehicle-item:hover {
      background: #f0f0f0;
    }

    /* Cartões com altura fixa */
    .standard-card {
      border-radius: 0.5rem;
      height: 200px;
      overflow: hidden;
    }

    .standard-card .card-header {
      background-color: rgba(0, 0, 0, 0.05);
      font-weight: bold;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1rem;
    }

    .standard-card .card-body {
      padding: 1rem;
      height: calc(200px - 3rem);
      /* Altura total menos o header */
      overflow-y: auto;
    }
  </style>

  <style>
    /* Aplica transição suave em qualquer marcador com a classe .vehicle-marker-icon */
    .vehicle-marker-icon.leaflet-marker-icon {
      transition: transform 0.5s linear;
    }
  </style>

  <style>
    /* Zoom-level control */
    .zoom-level-control {
      background: white;
      padding: 6px;
      border-radius: 6px;
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.25);
    }

    .zoom-level-control button {
      display: block;
      width: 110px;
      text-align: left;
      padding: 4px 8px;
      margin: 3px 0;
      font-size: 0.9rem;
      border: none;
      background: transparent;
      cursor: pointer;
    }

    .zoom-level-control button:hover {
      background: rgba(0, 0, 0, 0.05);
      border-radius: 4px;
    }
  </style>

</head>

<body>
  <div class="container-fluid mt-4">
    <!-- Cabeçalho da Página -->
    <div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
      <div>
        <h1>Controle de Frota</h1>
        <div id="datetime" class="text-center mb-2" style="font-size:0.75rem; line-height:1rem; color:#666;">
        </div>

        <span class="navbar-text text-dark">
          <i class="bi bi-person-circle"></i>
          <%= user ? user.email : 'Usuário' %> - <%= user ? user.role : 'Sem Permissão' %>
        </span>
      </div>
      <!-- Card de sessão (mesmo HTML anterior, com IDs) -->
      <div class="d-flex justify-content-end">
        <div class="card shadow-sm rounded-lg my-3" style="max-width: 350px;">
          <div class="card-body p-2">
            <h5 class="card-title mb-2">Sessão</h5>

            <p class="mb-1">
              <small>
                <i class="fa-solid fa-user-clock fa-fw me-1" aria-hidden="true"></i>
                <strong>Logado:</strong>
              </small>
              <span id="sess-elapsed" class="badge bg-primary badge-sm">--m --s</span>
            </p>

            <p class="mb-2">
              <small>
                <i class="fa-solid fa-hourglass-half fa-fw me-1" aria-hidden="true"></i>
                <strong>Restante:</strong>
              </small>
              <span id="sess-remaining" class="badge bg-warning text-dark badge-sm">--m --s</span>
            </p>
          </div>

        </div>
      </div>
    </div>

    <!-- Lista de Veículos -->
    <div class="mb-4 border-bottom pt-3 pb-2 mb-3">
      <p>Escolha um veículo para registrar o uso:</p>
      <table class="table table-striped">
        <thead>
          <tr>
            <th>Veículo</th>
            <th>Placa</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% veiculos.forEach(veiculo=> { %>
            <tr>
              <td>
                <%= veiculo.nome %>
              </td>
              <td>
                <%= veiculo.placa %>
              </td>
              <td>
                <a href="/usar/<%= veiculo.id %>" class="btn btn-primary" data-bs-toggle="tooltip"
                  data-bs-placement="top"
                  title="Cada deslocamento é um uso diferente. Ex.: ir da empresa ao SAMU é um uso, e voltar do SAMU à empresa é outro uso.">
                  <i class="bi bi-play-circle"></i> Registrar Uso
                </a>
                <% if (user.role==='admin' ) { %>
                  <a href="/registrar-multa/<%= veiculo.id %>" class="btn btn-danger">
                    <i class="bi bi-exclamation-triangle"></i> Registrar Multas
                  </a>
                  <% } %>
                    <a href="/editar-veiculo/<%= veiculo.id %>" class="btn btn-warning">
                      <i class="bi bi-pencil-square"></i> Editar
                    </a>
                    <% if (user.role==='admin' ) { %>
                      <form action="/excluir-veiculo/<%= veiculo.id %>" method="POST" style="display:inline;" onsubmit="
                          if (!confirm('Esse veículo tem <%= veiculo.manutCount %> manutenção(ões) vinculada(s). Deseja prosseguir e removê-las?')) return false;
                          if (!confirm('Esse veículo tem <%= veiculo.multaCount %> multa(s) vinculada(s). Deseja prosseguir e removê-las?')) return false;
                          if (!confirm('Esse veículo tem <%= veiculo.usoCount %> uso(s) vinculados. Deseja prosseguir e removê-los?')) return false;
                          return confirm('Exclusão final: isto é irreversível. Tem certeza?');
                        ">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" class="btn btn-danger">
                          <i class="bi bi-trash"></i> Excluir
                        </button>
                      </form>
                      <% } %>

              </td>
            </tr>
            <% }); %>
        </tbody>
      </table>
      <div class="d-flex gap-2">
        <a href="/relatorio-uso" class="btn btn-secondary">
          <i class="bi bi-file-earmark-text"></i> Finalizar-editar Uso / Ver Relatório de Uso
        </a>
        <% if (user.role==='admin' ) { %>
          <a href="/registrar-veiculo" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Registrar Veículo
          </a>
          <% } %>
      </div>
    </div>

    <div class="row mb-3 align-items-center">
      <!-- Label sempre ocupa uma coluna automática -->
      <div class="col-12 col-md-auto mb-2 mb-md-0">

        <label for="deviceSelect" class="form-label">Selecione o dispositivo:</label>
      </div>


      <!-- Em volta do select, no seu EJS -->
      <div class="input-group">
        <span class="input-group-text">
          <i class="fas fa-car"></i>
        </span>
        <select id="deviceSelect" class="form-select">
          <option>Carregando...</option>
        </select>
        <span id="deviceSpinner" class="input-group-text d-none">
          <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
        </span>
        <button id="btnMostrarTodos" class="btn btn-outline-primary" type="button" title="Mostrar a última posição de todos os dispositivos">
          <i class="bi bi-collection"></i> Mostrar todos
        </button>
      </div>
    </div>

    <div class="d-flex flex-column vh-100 p-0">
      <div class="bg-light py-2 text-center w-100">
        <h1 class="h4 mb-1">Mapa de Localização GPS</h1>
        <p class="small text-muted mb-0">💡 Em celular, use na horizontal para melhor aproveitamento</p>
      </div>
      <div id="map" class="flex-fill border-0 rounded-0 mb-2"></div>
    </div>

    <% if (user.role==='admin' ) { %>
      <div class="accordion" id="statsAccordion">

        <!-- 1) Informações Gerais -->
        <div class="accordion-item">
          <h2 class="accordion-header" id="headingGeneral">
            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseGeneral"
              aria-expanded="true" aria-controls="collapseGeneral">
              <i class="bi bi-bar-chart-fill me-2"></i> Informações Gerais
            </button>
          </h2>
          <div id="collapseGeneral" class="accordion-collapse collapse show" aria-labelledby="headingGeneral"
            data-bs-parent="#statsAccordion">
            <div class="accordion-body">
              <div class="row mb-4">
                <h4 class="mb-3">Informações Gerais</h4>
                <!-- Motoristas com CNH válida -->
                <div class="col-md-3">
                  <div class="card standard-card text-white bg-success mb-3">
                    <div class="card-header"><i class="bi bi-check-circle"></i> Motoristas que Podem Dirigir</div>
                    <div class="card-body">
                      <p class="display-6">
                        <%= totalMotoristasValidos || 0 %>
                      </p>
                      <p>CNH válida</p>
                    </div>
                  </div>
                </div>
                <!-- Motoristas com CNH vencida -->
                <div class="col-md-3">
                  <div class="card standard-card text-white bg-danger mb-3">
                    <div class="card-header"><i class="bi bi-x-circle"></i> Motoristas que Não Podem Dirigir</div>
                    <div class="card-body">
                      <p class="display-6">
                        <%= totalMotoristasInvalidos || 0 %>
                      </p>
                      <p>CNH vencida</p>
                    </div>
                  </div>
                </div>
                <!-- Lista: Motoristas Válidos -->
                <div class="col-md-3">
                  <div class="card mb-3">
                    <div class="card-header bg-success text-white">Motoristas que Podem Dirigir</div>
                    <div class="card-body" style="max-height:200px;overflow-y:auto">
                      <ul class="list-group list-group-flush">
                        <% motoristasValidosList.forEach(motorista=> { %>
                          <li class="list-group-item">
                            <strong>
                              <%= motorista.nome %>
                            </strong> - <%= motorista.email %><br>
                              <small>Validade: <%= motorista.validade %></small>
                          </li>
                          <% }) %>
                      </ul>
                    </div>
                  </div>
                </div>
                <!-- Lista: Motoristas Inválidos -->
                <div class="col-md-3">
                  <div class="card mb-3">
                    <div class="card-header bg-danger text-white">Motoristas que Não Podem Dirigir</div>
                    <div class="card-body" style="max-height:200px;overflow-y:auto">
                      <ul class="list-group list-group-flush">
                        <% motoristasInvalidosList.forEach(motorista=> { %>
                          <li class="list-group-item">
                            <strong>
                              <%= motorista.nome %>
                            </strong> - <%= motorista.email %><br>
                              <small>Validade: <%= motorista.validade %></small>
                          </li>
                          <% }) %>
                      </ul>
                    </div>
                  </div>
                </div>
                <!-- Veículos -->
                <div class="col-md-3">
                  <div class="card standard-card text-white bg-primary mb-3">
                    <div class="card-header"><i class="bi bi-truck"></i> Veículos</div>
                    <div class="card-body">
                      <p class="display-6">
                        <%= totalVeiculos || 0 %>
                      </p>
                      <p>Veículos cadastrados</p>
                    </div>
                  </div>
                </div>
                <!-- Multas -->
                <div class="col-md-3">
                  <div class="card standard-card text-white bg-danger mb-3">
                    <div class="card-header"><i class="bi bi-exclamation-octagon"></i> Multas</div>
                    <div class="card-body">
                      <p class="display-6">
                        <%= totalMultas || 0 %>
                      </p>
                      <p>Multas registradas</p>
                    </div>
                  </div>
                </div>
                <!-- Uso -->
                <div class="col-md-3">
                  <div class="card standard-card text-white bg-success mb-3">
                    <div class="card-header"><i class="bi bi-speedometer2"></i> Uso</div>
                    <div class="card-body">
                      <p class="display-6">
                        <%= totalUso || 0 %>
                      </p>
                      <p>Registros de uso</p>
                    </div>
                  </div>
                </div>
                <!-- Motoristas Ativos -->
                <div class="col-md-3">
                  <div class="card standard-card text-white bg-warning mb-3">
                    <div class="card-header"><i class="bi bi-people"></i> Motoristas Ativos</div>
                    <div class="card-body">
                      <p class="display-6">
                        <%= totalMotoristasAtivos || 0 %>
                      </p>
                      <p>Em atividade</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 2) Relatórios de Uso -->
        <div class="accordion-item">
          <h2 class="accordion-header" id="headingUso">
            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
              data-bs-target="#collapseUso" aria-expanded="false" aria-controls="collapseUso">
              <i class="bi bi-calendar-day me-2"></i> Relatórios de Uso
            </button>
          </h2>
          <div id="collapseUso" class="accordion-collapse collapse" aria-labelledby="headingUso"
            data-bs-parent="#statsAccordion">
            <div class="accordion-body">
              <div class="row mb-4">
                <h4 class="mb-3">Relatórios de Uso</h4>
                <!-- Uso por Dia -->
                <div class="col-md-4">
                  <div class="card standard-card text-white bg-info mb-3">
                    <div class="card-header"><i class="bi bi-calendar-day"></i> Uso por Dia</div>
                    <div class="card-body">
                      <% if (usoDia.length> 0) { %>
                        <% usoDia.forEach(item=> { %>
                          <p class="mb-1">
                            <strong>
                              <%= new Intl.DateTimeFormat('pt-BR', { weekday:'long', day:'2-digit', month:'2-digit',
                                year:'numeric' }).format(new Date(item.dia)) %>:
                            </strong>
                            <%= item.totalUsoDia %> usos<br>
                              <small>🕒 <%= item.primeiroUso %> / <%= item.ultimoUso %></small>
                          </p>
                          <% }) %>
                            <% } else { %>
                              <p>Nenhum uso registrado.</p>
                              <% } %>
                    </div>
                  </div>
                </div>
                <!-- Uso por Mês -->
                <div class="col-md-4">
                  <div class="card standard-card text-white bg-success mb-3">
                    <div class="card-header"><i class="bi bi-calendar3"></i> Uso por Mês</div>
                    <div class="card-body">
                      <% if (usoMes.length> 0) { %>
                        <% usoMes.forEach(item=> { %>
                          <p class="mb-1"><strong>
                              <%= item.mes %>:
                            </strong>
                            <%= item.totalUsoMes %> usos
                          </p>
                          <% }) %>
                            <% } else { %>
                              <p>Nenhum uso registrado.</p>
                              <% } %>
                    </div>
                  </div>
                </div>
                <!-- Uso por Ano -->
                <div class="col-md-4">
                  <div class="card standard-card text-white bg-warning mb-3">
                    <div class="card-header"><i class="bi bi-calendar4"></i> Uso por Ano</div>
                    <div class="card-body">
                      <% if (usoAno.length> 0) { %>
                        <% usoAno.forEach(item=> { %>
                          <p class="mb-1"><strong>
                              <%= item.ano %>:
                            </strong>
                            <%= item.totalUsoAno %> usos
                          </p>
                          <% }) %>
                            <% } else { %>
                              <p>Nenhum uso registrado.</p>
                              <% } %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 3) Relatórios de Multas -->
        <div class="accordion-item">
          <h2 class="accordion-header" id="headingMultas">
            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
              data-bs-target="#collapseMultas" aria-expanded="false" aria-controls="collapseMultas">
              <i class="bi bi-exclamation-octagon me-2"></i> Relatórios de Multas
            </button>
          </h2>
          <div id="collapseMultas" class="accordion-collapse collapse" aria-labelledby="headingMultas"
            data-bs-parent="#statsAccordion">
            <div class="accordion-body">
              <div class="row mb-4">
                <h4 class="mb-3">Relatórios de Multas</h4>
                <!-- Multas por Mês -->
                <div class="col-md-4">
                  <div class="card standard-card text-white bg-secondary mb-3">
                    <div class="card-header"><i class="bi bi-calendar3"></i> Multas por Mês</div>
                    <div class="card-body">
                      <% if (multasMes.length> 0) { %>
                        <% multasMes.forEach(item=> { %>
                          <p class="mb-1"><strong>
                              <%= item.mes %>:
                            </strong>
                            <%= item.totalMultasMes %> multas
                          </p>
                          <% }) %>
                            <% } else { %>
                              <p>Nenhuma multa registrada.</p>
                              <% } %>
                    </div>
                  </div>
                </div>
                <!-- Multas por Ano -->
                <div class="col-md-4">
                  <div class="card standard-card text-white bg-dark mb-3">
                    <div class="card-header"><i class="bi bi-calendar4"></i> Multas por Ano</div>
                    <div class="card-body">
                      <% if (multasAno.length> 0) { %>
                        <% multasAno.forEach(item=> { %>
                          <p class="mb-1"><strong>
                              <%= item.ano %>:
                            </strong>
                            <%= item.totalMultasAno %> multas
                          </p>
                          <% }) %>
                            <% } else { %>
                              <p>Nenhuma multa registrada.</p>
                              <% } %>
                    </div>
                  </div>
                </div>
                <!-- Multas por Motorista -->
                <div class="col-md-4">
                  <div class="card standard-card text-white bg-info mb-3">
                    <div class="card-header"><i class="bi bi-people"></i> Multas por Motorista</div>
                    <div class="card-body">
                      <% if (multasMotorista.length> 0) { %>
                        <% multasMotorista.forEach(item=> { %>
                          <p class="mb-1"><strong>
                              <%= item.motorista %>:
                            </strong>
                            <%= item.totalMultasMotorista %> multas
                          </p>
                          <% }) %>
                            <% } else { %>
                              <p>Nenhuma multa registrada.</p>
                              <% } %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 4) KM Rodados -->
        <div class="accordion-item">
          <h2 class="accordion-header" id="headingKm">
            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
              data-bs-target="#collapseKm" aria-expanded="false" aria-controls="collapseKm">
              <i class="bi bi-speedometer2 me-2"></i> KM Rodados
            </button>
          </h2>
          <div id="collapseKm" class="accordion-collapse collapse" aria-labelledby="headingKm"
            data-bs-parent="#statsAccordion">
            <div class="accordion-body">
              <div class="row mb-4">
                <h4 class="mb-3">KM Rodados</h4>
                <!-- KM por Motorista -->
                <div class="col-md-3">
                  <div class="card mb-3">
                    <div class="card-header bg-primary text-white">KM por Motorista</div>
                    <div class="card-body" style="max-height:200px;overflow-y:auto">
                      <ul class="list-group list-group-flush">
                        <% kmMotorista.forEach(m=> { %>
                          <li class="list-group-item"><strong>
                              <%= m.motorista %>
                            </strong>: <%= m.totalKm %> km</li>
                          <% }) %>
                      </ul>
                    </div>
                  </div>
                </div>
                <!-- KM por Viagem -->
                <div class="col-md-3">
                  <div class="card mb-3">
                    <div class="card-header bg-secondary text-white">KM por Viagem (Últ.10)</div>
                    <div class="card-body" style="max-height:200px;overflow-y:auto">
                      <ul class="list-group list-group-flush">
                        <% kmViagem.forEach(v=> { %>
                          <li class="list-group-item">Viagem #<%= v.viagemId %>: <%= v.kmViagem %> km</li>
                          <% }) %>
                      </ul>
                    </div>
                  </div>
                </div>
                <!-- KM por Dia -->
                <div class="col-md-3">
                  <div class="card mb-3">
                    <div class="card-header bg-info text-white">KM por Dia (Últ.7 dias)</div>
                    <div class="card-body" style="max-height:200px;overflow-y:auto">
                      <ul class="list-group list-group-flush">
                        <% kmDia.forEach(d=> { %>
                          <li class="list-group-item"><strong>
                              <%= d.dia %>
                            </strong>: <%= d.totalKmDia %> km</li>
                          <% }) %>
                      </ul>
                    </div>
                  </div>
                </div>
                <!-- KM por Mês -->
                <div class="col-md-3">
                  <div class="card mb-3">
                    <div class="card-header bg-warning text-dark">KM por Mês (Últ.6 meses)</div>
                    <div class="card-body" style="max-height:200px;overflow-y:auto">
                      <ul class="list-group list-group-flush">
                        <% kmMes.forEach(m=> { %>
                          <li class="list-group-item"><strong>
                              <%= m.mes %>
                            </strong>: <%= m.totalKmMes %> km</li>
                          <% }) %>
                      </ul>
                    </div>
                  </div>
                </div>
                <!-- KM por Ano -->
                <div class="col-md-3">
                  <div class="card mb-3">
                    <div class="card-header bg-dark text-white">KM por Ano (Últ.5 anos)</div>
                    <div class="card-body" style="max-height:200px;overflow-y:auto">
                      <ul class="list-group list-group-flush">
                        <% kmAno.forEach(a=> { %>
                          <li class="list-group-item"><strong>
                              <%= a.ano %>
                            </strong>: <%= a.totalKmAno %> km</li>
                          <% }) %>
                      </ul>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 5) Relatórios de Viagens -->
        <div class="accordion-item">
          <h2 class="accordion-header" id="headingViagens">
            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
              data-bs-target="#collapseViagens" aria-expanded="false" aria-controls="collapseViagens">
              <i class="bi bi-geo-alt me-2"></i> Relatórios de Viagens
            </button>
          </h2>
          <div id="collapseViagens" class="accordion-collapse collapse" aria-labelledby="headingViagens"
            data-bs-parent="#statsAccordion">
            <div class="accordion-body">
              <div class="row mb-4">
                <h4 class="mb-3">Relatórios de Viagens</h4>
                <!-- Viagens por Dia -->
