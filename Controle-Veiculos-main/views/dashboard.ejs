  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet.fullscreen/1.6.0/Control.FullScreen.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/socket.io/socket.io.js"></script>

  <script>
    // toltips
    document.addEventListener('DOMContentLoaded', () => {
      const tooltipTriggerList = Array.from(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
      tooltipTriggerList.forEach(el => new bootstrap.Tooltip(el));
    });
  </script>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const deviceSelect = document.getElementById('deviceSelect');
      const spinner = document.getElementById('deviceSpinner');

      // Inicia Mapa
      const map = L.map('map').setView([-23.55, -46.63], 12);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors'
      }).addTo(map);
      L.control.fullscreen({ position: 'topleft' }).addTo(map);

      // Reposiciona o "X" do popup
      map.on('popupopen', e => {
        const c = e.popup._container;
        if (!c) return;
        c.style.overflow = 'visible';
        c.style.maxWidth = '300px';
        c.style.maxHeight = '200px';
        const btn = c.querySelector('.leaflet-popup-close-button');
        if (btn) {
          btn.style.top = '10px';
          btn.style.right = '6px';
        }
      });

      // “Voltar ao veículo”
      const ReturnControl = L.Control.extend({
        options: { position: 'topleft' },
        onAdd() {
          const btn = L.DomUtil.create('button', 'leaflet-bar leaflet-control');
          btn.innerHTML = '<i class="fas fa-crosshairs"></i>';
          Object.assign(btn.style, {
            width: '34px', height: '34px', lineHeight: '34px',
            textAlign: 'center', fontSize: '18px', cursor: 'pointer'
          });
          btn.addEventListener('click', e => {
            L.DomEvent.stopPropagation(e);
            try {
              const p = vehicleMarker.getLatLng();
              if (p) {
                map.flyTo(p, 16, { animate: true, duration: 0.5 });
                vehicleMarker.openPopup();
              }
            } catch (err) { /* ignore */ }
          });
          return btn;
        }
      });
      map.addControl(new ReturnControl());

      // Zoom-level control (bairro/rua/cidade/estado)
      const ZoomLevelControl = L.Control.extend({
        options: { position: 'topleft' },
        onAdd() {
          const container = L.DomUtil.create('div', 'zoom-level-control leaflet-bar');
          container.innerHTML = `
            <div class="d-flex flex-column">
              <strong style="font-size:0.9rem; padding:4px 6px;">Zoom</strong>
              <button id="zoom-rua" title="Rua">Rua</button>
              <button id="zoom-bairro" title="Bairro">Bairro</button>
              <button id="zoom-cidade" title="Cidade">Cidade</button>
              <button id="zoom-estado" title="Estado">Estado</button>
            </div>
          `;
          L.DomEvent.disableClickPropagation(container);
          return container;
        }
      });
      const zoomCtrl = new ZoomLevelControl();
      map.addControl(zoomCtrl);

      // Mapeamento de níveis (ajuste se quiser outros valores)
      const ZOOM_LEVELS = { rua: 18, bairro: 15, cidade: 12, estado: 7 };

      // Reverse geocoding cache simples
      const addressCache = new Map(); // key: `${lat.toFixed(5)}|${lng.toFixed(5)}` -> address string

      async function reverseGeocode(lat, lng) {
        const key = `${lat.toFixed(5)}|${lng.toFixed(5)}`;
        if (addressCache.has(key)) return addressCache.get(key);
        try {
          const url = `https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${encodeURIComponent(lat)}&lon=${encodeURIComponent(lng)}&accept-language=pt-BR`;
          const res = await fetch(url, { headers: { 'User-Agent': 'ControleFrota/1.0 (contato@example.com)' } });
          if (!res.ok) throw new Error('geocode fail');
          const data = await res.json();
          const addr = data.display_name || (data.address ? Object.values(data.address).join(', ') : null) || 'Endereço não encontrado';
          addressCache.set(key, addr);
          return addr;
        } catch (e) {
          console.warn('Erro reverseGeocode', e);
          return 'Endereço não disponível';
        }
      }

      // Versão atualizada — prioriza nome_marca / nome_modelo salvos no backend
      async function loadDevicesDebug() {
        try {
          console.clear();
          console.log('> loadDevicesDebug: iniciando...');

          spinner.classList.remove('d-none');

          // 1) buscar dispositivos do backend
          console.log('> fetch /devices-com-veiculo ...');
          const res = await fetch('/devices-com-veiculo');
          console.log('> status /devices-com-veiculo:', res.status, res.statusText);
          if (!res.ok) {
            const text = await res.text().catch(() => null);
            console.error('> Erro na requisição /devices-com-veiculo:', res.status, text);
            throw new Error('Erro na requisição /devices-com-veiculo');
          }

          const devs = await res.json();
          console.log('> dados recebidos do backend (devs):', devs);
          console.log('> total devices retornados:', Array.isArray(devs) ? devs.length : 'não é array');

          const FIPE_BASE = 'https://parallelum.com.br/fipe/api/v1';

          const marcasParaBuscar = new Set();
          let precisaCarregarMarcasFIPE = false;
          devs.forEach(d => {
            const hasNomeMarca = d.nome_marca && String(d.nome_marca).trim() !== '';
            const hasNomeModelo = d.nome_modelo && String(d.nome_modelo).trim() !== '';
            const marcaIsCode = d.marca && /^\d+$/.test(String(d.marca));
            const modeloIsCode = d.modelo && /^\d+$/.test(String(d.modelo));
            if (!hasNomeMarca && marcaIsCode) {
              marcasParaBuscar.add(String(d.marca));
              precisaCarregarMarcasFIPE = true;
            }
            if (!hasNomeModelo && modeloIsCode) {
              if (marcaIsCode) marcasParaBuscar.add(String(d.marca));
              precisaCarregarMarcasFIPE = true;
            }
          });

          let marcaCodeToNome = {};
          if (precisaCarregarMarcasFIPE) {
            try {
              const fipeMarcasResp = await fetch(`${FIPE_BASE}/carros/marcas`);
              if (fipeMarcasResp.ok) {
                const fipeMarcas = await fipeMarcasResp.json();
                (fipeMarcas || []).forEach(m => {
                  if (m && m.codigo !== undefined) marcaCodeToNome[String(m.codigo)] = m.nome;
                });
              }
            } catch (e) { /* ignora */ }
          }

          const marcaCodigoParaModelosMap = {};
          if (Object.keys(marcaCodeToNome).length && marcasParaBuscar.size) {
            await Promise.all(Array.from(marcasParaBuscar).map(async marcaCode => {
              try {
                const resp = await fetch(`${FIPE_BASE}/carros/marcas/${marcaCode}/modelos`);
                if (!resp.ok) return;
                const data = await resp.json();
                const modelosArr = Array.isArray(data) ? data : (Array.isArray(data.modelos) ? data.modelos : []);
                const modelosMap = {};
                modelosArr.forEach(mo => {
                  if (mo && mo.codigo !== undefined) modelosMap[String(mo.codigo)] = mo.nome;
                });
                marcaCodigoParaModelosMap[marcaCode] = modelosMap;
              } catch (e) { /* ignora */ }
            }));
          }

          const resolvedDevs = devs.map(d => {
            let marcaResolvida = (d.nome_marca && String(d.nome_marca).trim() !== '') ? String(d.nome_marca).trim() : null;
            let modeloResolvido = (d.nome_modelo && String(d.nome_modelo).trim() !== '') ? String(d.nome_modelo).trim() : null;
            if (!marcaResolvida) {
              if (d.marca && /^\d+$/.test(String(d.marca))) marcaResolvida = marcaCodeToNome[String(d.marca)] || null;
              else if (d.marca) marcaResolvida = String(d.marca).trim();
            }
            if (!modeloResolvido) {
              if (d.modelo && /^\d+$/.test(String(d.modelo))) {
                const marcaCode = (d.marca && /^\d+$/.test(String(d.marca))) ? String(d.marca) : null;
                if (marcaCode && marcaCodigoParaModelosMap[marcaCode]) {
                  modeloResolvido = marcaCodigoParaModelosMap[marcaCode][String(d.modelo)] || null;
                } else {
                  for (const [mCod, modelosMap] of Object.entries(marcaCodigoParaModelosMap)) {
                    if (modelosMap && modelosMap[String(d.modelo)]) {
                      modeloResolvido = modelosMap[String(d.modelo)];
                      if (!marcaResolvida) marcaResolvida = marcaCodeToNome[mCod] || marcaResolvida;
                      break;
                    }
                  }
                }
              } else if (d.modelo) {
                modeloResolvido = String(d.modelo).trim();
              }
            }
            if (!marcaResolvida) marcaResolvida = 'Desconhecida';
            if (!modeloResolvido) modeloResolvido = 'Desconhecido';
            return { ...d, marcaResolvida, modeloResolvido };
          });

          // popular o select
          resolvedDevs.sort((a, b) => b.id - a.id);
          deviceSelect.innerHTML = '';
          resolvedDevs.forEach(d => {
            const opt = document.createElement('option');
            opt.value = d.id;
            opt.textContent = `${d.name} — Placa: ${d.placa || '—'} | Marca: ${d.marcaResolvida} | Modelo: ${d.modeloResolvido}`;
            deviceSelect.append(opt);
          });

          if (resolvedDevs.length) deviceSelect.dispatchEvent(new Event('change'));
        } catch (err) {
          deviceSelect.innerHTML = '<option>Erro ao carregar</option>';
          console.error('> loadDevicesDebug: erro geral:', err);
        } finally {
          spinner.classList.add('d-none');
        }
      }

      // Marcador principal
      const vehicleIcon = L.divIcon({
        html: '<i class="fas fa-car fa-2x"></i>',
        className: 'vehicle-marker-icon',
        iconSize: [32, 32],
        iconAnchor: [16, 16],
        popupAnchor: [0, -5]
      });

      let vehicleMarker = L.marker(map.getCenter(), { icon: vehicleIcon }).addTo(map);
      vehicleMarker.bindPopup('🚗 Veículo', { autoPan: true, closeButton: true, offset: L.point(0, -28) });

      let popupManuallyClosed = false;

      const allVehicleLayer = L.featureGroup().addTo(map);
      const allVehicleMarkers = {};
      const colors = ['#e74c3c', '#3498db', '#27ae60', '#f39c12', '#8e44ad', '#c0392b', '#2c3e50'];
      let autoPan = true, socket;

      // listener do select
      deviceSelect.addEventListener('change', () => {
        const devId = deviceSelect.value;
        if (!devId) return;
        autoPan = true;

        // desconecta socket anterior
        if (socket) {
          try { socket.emit('unsubscribeFromDevice', socket.deviceId || devId); } catch (e) { }
          socket.disconnect();
          socket = null;
        }

        vehicleMarker.setLatLng(map.getCenter());

        vehicleMarker.off('click');
        vehicleMarker.on('click', () => {
          popupManuallyClosed = false;
          vehicleMarker.togglePopup();
          const p = vehicleMarker.getLatLng();
          if (p) map.flyTo(p, 16, { animate: true, duration: 0.5 });
        });

        vehicleMarker.off('popupclose');
        vehicleMarker.on('popupclose', () => { popupManuallyClosed = true; });

        // Histórico único (busca último ponto e resolve endereço)
        fetch(`/gps-history?device=${devId}`)
          .then(r => r.ok ? r.json() : Promise.reject())
          .then(async hist => {
            if (!hist.length) return;
            const last = hist[hist.length - 1];
            const lat = +last.latitude, lng = +last.longitude;
            const dt = new Date(last.datahora_recebido);
            let addr = await reverseGeocode(lat, lng).catch(() => 'Endereço não disponível');
            const popupHtml =
              `<i class="fas fa-car"></i> ${deviceSelect.selectedOptions[0].text}<br>` +
              `<small class="text-muted">${dt.toLocaleDateString('pt-BR')} ${dt.toLocaleTimeString('pt-BR')}</small><br>` +
              `<strong>Lat:</strong> ${lat.toFixed(6)} &nbsp; <strong>Lng:</strong> ${lng.toFixed(6)}<br>` +
              `<small>${addr}</small>`;
            vehicleMarker.setLatLng([lat, lng]).setPopupContent(popupHtml);
            if (autoPan) map.panTo([lat, lng], { animate: true, duration: 0.5 });
          })
          .catch(() => console.error('Erro histórico'));

        // Socket.IO real-time
        socket = io();
        socket.deviceId = devId;
        let prevLat = null, prevLng = null, prevTime = null;

        socket.on('connect', () => socket.emit('subscribeToDevice', devId));
        socket.on('locationUpdate', async pt => {
          const lat = +pt.latitude, lng = +pt.longitude, currTime = new Date(pt.datahora_recebido);

          let popupHtml = `<i class="fas fa-car"></i> ${deviceSelect.selectedOptions[0].text}<br>` +
            `<small class="text-muted">${currTime.toLocaleDateString('pt-BR')} ${currTime.toLocaleTimeString('pt-BR')}</small>`;

          if (prevTime !== null) {
            const dist = L.latLng(prevLat, prevLng).distanceTo(L.latLng(lat, lng)); // m
            const dtSec = (currTime - prevTime) / 1000; // s
            const speedKmh = dtSec > 0 ? (dist / dtSec) * 3.6 : 0; // km/h
            popupHtml += `<br><strong>Velocidade:</strong> ${speedKmh.toFixed(1)} km/h`;
          }

          popupHtml += `<br><strong>Lat:</strong> ${lat.toFixed(6)} &nbsp; <strong>Lng:</strong> ${lng.toFixed(6)}`;

          // Resolve endereço assíncrono e atualiza popup quando pronto
          vehicleMarker.setLatLng([lat, lng]).setPopupContent(popupHtml + '<br><em>Carregando endereço...</em>');

          // Atualiza endereço em background
          const addr = await reverseGeocode(lat, lng).catch(() => 'Endereço não disponível');
          const popupWithAddr = popupHtml + `<br><small>${addr}</small>`;
          vehicleMarker.getPopup().setContent(popupWithAddr);

          if (vehicleMarker.isPopupOpen() && !popupManuallyClosed) {
            // garante atualização visual
            vehicleMarker.getPopup().update();
          }

          prevLat = lat; prevLng = lng; prevTime = currTime;

          if (autoPan) map.panTo([lat, lng], { animate: true, duration: 0.5 });
        });
      });

      // "Mostrar Todos"
      document.getElementById('btnMostrarTodos').addEventListener('click', async () => {
        if (map.hasLayer(vehicleMarker)) map.removeLayer(vehicleMarker);
        allVehicleLayer.clearLayers();
        Object.keys(allVehicleMarkers).forEach(id => delete allVehicleMarkers[id]);

        const opts = Array.from(deviceSelect.options).filter(o => o.value);
        const promises = opts.map((o, idx) =>
          fetch(`/gps-history?device=${o.value}`)
            .then(r => r.ok ? r.json() : Promise.reject())
            .then(h => h.length ? { id: o.value, last: h[h.length - 1], color: colors[idx % colors.length], deviceText: o.textContent } : null)
            .catch(() => null)
        );

        const list = await Promise.all(promises);
        list.forEach(async d => {
          if (!d) return;
          const lat = +d.last.latitude, lng = +d.last.longitude;
          const dt = new Date(d.last.datahora_recebido);
          const mk = L.marker([lat, lng], {
            icon: L.divIcon({
              html: `<i class="fas fa-car fa-lg" style="color:${d.color}"></i>`,
              className: 'vehicle-marker-icon',
              iconSize: [24, 24], iconAnchor: [12, 12], popupAnchor: [0, -12]
            })
          });
          const addr = await reverseGeocode(lat, lng).catch(() => 'Endereço não disponível');
          mk.bindPopup(`${d.deviceText}<br>Atualizado em: ${dt.toLocaleDateString('pt-BR')} ${dt.toLocaleTimeString('pt-BR')}<br><strong>Lat:</strong> ${lat.toFixed(6)} <strong>Lng:</strong> ${lng.toFixed(6)}<br><small>${addr}</small>`);
          allVehicleLayer.addLayer(mk);
          allVehicleMarkers[d.id] = mk;
        });
      });

      // Eventos dos botões de zoom
      document.getElementById('zoom-rua').addEventListener('click', () => {
        const p = vehicleMarker.getLatLng();
        if (p) map.setView(p, ZOOM_LEVELS.rua);
      });
      document.getElementById('zoom-bairro').addEventListener('click', () => {
        const p = vehicleMarker.getLatLng();
        if (p) map.setView(p, ZOOM_LEVELS.bairro);
      });
      document.getElementById('zoom-cidade').addEventListener('click', () => {
        const p = vehicleMarker.getLatLng();
        if (p) map.setView(p, ZOOM_LEVELS.cidade);
      });
      document.getElementById('zoom-estado').addEventListener('click', () => {
        const p = vehicleMarker.getLatLng();
        if (p) map.setView(p, ZOOM_LEVELS.estado);
      });

      // Força redraw
      setTimeout(() => map.invalidateSize(), 500);

      // Carrega devices
      loadDevicesDebug();
    });
  </script>

  <script>
    // Geofences (carrega separadamente para não bloquear)
    (async function loadGeofences() {
      try {
        const res = await fetch('/geofences-json');
        if (!res.ok) return;
        const data = await res.json();
        data.forEach(g => {
          try {
            const coords = g.wkt_polygon.slice(9, -2)
              .split(',')
              .map(p => p.trim().split(' ').reverse().map(Number));
            if (!coords.length) return;
            L.polygon(coords, {
              color: 'red', weight: 2, dashArray: '5,5', fillOpacity: 0.1
            })
              .addTo(window.map || L.map('map')) // se map disponível
              .bindPopup(`<strong>${g.nome}</strong>`);
          } catch (err) { /* ignora polígonos inválidos */ }
        });
      } catch (e) { console.error('Erro geofences', e); }
    })();
  </script>

  <script>
    function updateDateTime() {
      const now = new Date();
      const options = {
        weekday: 'long',
        year: 'numeric',
        month: 'long',
        day: 'numeric',
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit'
      };
      document.getElementById('datetime').innerText = now.toLocaleDateString('pt-BR', options);
    }
    // Atualiza a cada segundo
    setInterval(updateDateTime, 1000);
    updateDateTime();
  </script>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      let elapsed, remaining;
      let localTimer, syncInterval;

      function updateDOM() {
        document.getElementById('sess-elapsed').textContent =
          `${elapsed.minutes}m ${elapsed.seconds}s`;
        document.getElementById('sess-remaining').textContent =
          `${remaining.minutes}m ${remaining.seconds}s`;
      }

      function tickLocal() {
        elapsed.seconds++;
        if (elapsed.seconds === 60) {
          elapsed.minutes++;
          elapsed.seconds = 0;
        }
        if (remaining.minutes > 0 || remaining.seconds > 0) {
          remaining.seconds--;
          if (remaining.seconds < 0) {
            remaining.minutes--;
            remaining.seconds = 59;
          }
        }
        updateDOM();
      }

      async function syncSession() {
        try {
          const res = await fetch('/session-info/json');
          if (!res.ok) throw new Error(res.status);
          const data = await res.json();
          elapsed = data.elapsed;
          remaining = data.remaining;
          updateDOM();
        } catch (err) {
          console.error('Erro ao buscar sessão:', err);
        }
      }

      (async () => {
        await syncSession();                          // 1. busca inicial
        localTimer = setInterval(tickLocal, 1000); // 2. contagem local
        syncInterval = setInterval(syncSession, 10000); // 3. sincroniza a cada 10s
      })();

      window.addEventListener('beforeunload', () => {
        clearInterval(localTimer);
        clearInterval(syncInterval);
      });
    });
  </script>
</body>

</html>
