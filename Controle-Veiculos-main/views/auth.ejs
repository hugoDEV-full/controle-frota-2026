<!DOCTYPE html>
<html lang="pt-br">

<head>
  <meta charset="UTF-8">
  <title>Autenticar Dispositivo</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-md-8">

        <div class="card shadow-sm">
          <div class="card-header text-center">
            <h4>Autenticar Dispositivo</h4>
          </div>
          <div class="card-body">

            <!-- Formulário de dados -->
            <form id="formAuth">
              <div class="row g-3">
                <div class="col-md-6">
                  <label class="form-label">IMEI</label>
                  <input type="text" class="form-control" name="IMEI" required>
                </div>
                <div class="col-md-6">
                  <label class="form-label">KEY (hash MD5)</label>
                  <input type="text" class="form-control" name="KEY" required>
                </div>
                <div class="col-md-4">
                  <label class="form-label">VERSION</label>
                  <input type="text" class="form-control" name="VERSION" required>
                </div>
                <div class="col-md-4">
                  <label class="form-label">OS</label>
                  <input type="text" class="form-control" name="OS" value="android" required>
                </div>
                <div class="col-md-4">
                  <label class="form-label">OS_V</label>
                  <input type="number" class="form-control" name="OS_V" value="29" required>
                </div>
                <div class="col-md-4">
                  <label class="form-label">ARCH</label>
                  <input type="text" class="form-control" name="ARCH" value="Handset" required>
                </div>
                <div class="col-md-4">
                  <label class="form-label">EXEC</label>
                  <input type="text" class="form-control" name="EXEC" required>
                </div>
                <div class="col-md-4">
                  <label class="form-label">DIR</label>
                  <input type="text" class="form-control" name="DIR" required>
                </div>
                <div class="col-md-6">
                  <label class="form-label">TAG</label>
                  <input type="text" class="form-control" name="TAG" required>
                </div>
              </div>
              <div class="mt-4 d-grid">
                <button type="submit" class="btn btn-primary">Autenticar</button>
              </div>
            </form>

            <!-- Status da autenticação -->
            <div id="statusBox" class="mt-4 alert d-none text-center"></div>

          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Socket.io e JS de controle -->
  <script src="/socket.io/socket.io.js"></script>
  <script>
    const form = document.getElementById('formAuth');
    const statusBox = document.getElementById('statusBox');

    form.addEventListener('submit', e => {
      e.preventDefault();
      statusBox.className = 'alert alert-info text-center';
      statusBox.textContent = 'Autenticando…';
      statusBox.classList.remove('d-none');

      // coleta dados do form
      const formData = new FormData(form);
      const payload = { REQ_ID: 1 };
      formData.forEach((value, key) => payload[key] = isNaN(value) ? value : Number(value));

      // Usa o mesmo origin da página:
      const socket = io({
        transports: ['websocket']
      });

      socket.on('connect', () => {
        socket.emit('auth-device', payload);
      });

      socket.on('auth-device-result', res => {
        if (res.header.SUCCESS === 1) {
          statusBox.className = 'alert alert-success text-center';
          statusBox.textContent = '✅ Autenticado com sucesso!';
        } else {
          statusBox.className = 'alert alert-danger text-center';
          statusBox.textContent = '❌ ' + res.MESSAGE;
        }
        socket.disconnect();
      });

      socket.on('connect_error', () => {
        statusBox.className = 'alert alert-danger text-center';
        statusBox.textContent = 'Erro ao conectar no WebSocket';
      });
    });
  </script>

</body>

</html>