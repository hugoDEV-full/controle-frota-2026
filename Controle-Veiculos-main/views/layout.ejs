    const toggleSidebar = document.getElementById('toggleSidebar');
    const sidebar = document.getElementById('sidebar');

    toggleSidebar.addEventListener('click', () => {
      sidebar.classList.toggle('collapsed');

      // atualiza atributo aria para acessibilidade
      const expanded = sidebar.classList.contains('collapsed') ? 'false' : 'true';
      toggleSidebar.setAttribute('aria-expanded', expanded);

      // animação do ícone (pequena rotação para indicar mudança) -- usa classe no botão
      toggleSidebar.querySelector('i').style.transform = sidebar.classList.contains('collapsed') ? 'rotate(0deg)' : 'rotate(0deg)';

    });
  </script>

  <script>
    /**
     * Bloqueia o menu de contexto (clique direito)
     * @param {MouseEvent|Event} e
     * @returns {boolean}
     */
    function disableContextMenu(e) {
      e.preventDefault();
      return false;
    }

    // Garantir que qualquer outro disparo de contextmenu seja bloqueado
    document.addEventListener('contextmenu', disableContextMenu);
  </script>
  <script>
    document.getElementById('link-viagens')
      .addEventListener('click', function (e) {
        e.preventDefault();
        document.getElementById('loading').style.display = 'flex';
        window.location.href = this.href;
      });
  </script>


  <script>
    /* Inline notifications JS - cole no layout.ejs antes do </body> */
    document.addEventListener('DOMContentLoaded', () => {
      const badge = document.getElementById('notifBadge');
      const list = document.getElementById('notifList');
      const markAllBtn = document.getElementById('markAllRead');
      const csrf = (typeof csrfToken !== 'undefined' && csrfToken) || document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');

      function updateBadgeCount(count) {
        if (!badge) return;
        badge.textContent = count > 99 ? '99+' : String(count);
        badge.style.display = (count && count > 0) ? 'inline-block' : 'none';
      }

      async function fetchCount() {
        try {
          const res = await fetch('/notifications/unread-count', { credentials: 'same-origin' });
          if (!res.ok) return;
          const j = await res.json();
          updateBadgeCount(j.count || 0);
        } catch (e) {
          console.warn('Erro fetchCount notifications:', e);
        }
      }

      async function fetchList() {
        if (!list) return;
        // placeholder de carregamento
        list.innerHTML = '<div class="px-3 py-2 text-muted small">Carregando...</div>';
        try {
          const res = await fetch('/notifications/list', {
            credentials: 'same-origin',
            headers: { 'Accept': 'application/json' }
          });
          const raw = await res.text();
          let rows;
          try {
            rows = raw ? JSON.parse(raw) : [];
          } catch (parseErr) {
            console.warn('Resposta não-JSON de /notifications/list:', raw, parseErr);
            list.innerHTML = '<div class="px-3 py-2 text-danger small">Erro ao interpretar resposta do servidor</div>';
            return;
          }
          if (!res.ok) {
            // Se veio JSON mas com status não-OK, trate como vazio ou mensagem amigável
            if (Array.isArray(rows)) {
              list.innerHTML = rows.length ? '' : '<div class="px-3 py-2 text-muted small">Sem notificações</div>';
              rows.forEach(r => {
                const item = document.createElement('div');
                item.className = 'dropdown-item d-flex align-items-start';
                if (!r.lida) item.classList.add('bg-light');
                item.innerHTML = `
              <div class=\"flex-grow-1\">
                <div class=\"small text-muted\">${new Date(r.criado_em).toLocaleString()}</div>
                <div>${r.mensagem}</div>
              </div>
              <div class=\"ms-2\">
                <button class=\"btn btn-sm btn-outline-secondary mark-read\" data-id=\"${r.id}\">OK</button>
              </div>`;
                list.appendChild(item);
              });
              // bind dos botões OK
              list.querySelectorAll('.mark-read').forEach(btn => {
                btn.addEventListener('click', async (e) => {
                  const id = e.currentTarget.dataset.id;
                  const csrfLocal = csrf || document.querySelector('meta[name=\"csrf-token\"]')?.getAttribute('content');
                  await fetch(`/notifications/mark-read/${id}`, { method: 'POST', credentials: 'same-origin', headers: csrfLocal ? { 'X-CSRF-Token': csrfLocal } : undefined });
                  fetchCount();
                  fetchList();
                });
              });
              return;
            }
            list.innerHTML = `<div class=\"px-3 py-2 text-danger small\">Erro ao carregar notificações (HTTP ${res.status})</div>`;
            return;
          }
          list.innerHTML = '';
          if (!Array.isArray(rows) || !rows.length) {
            list.innerHTML = '<div class="px-3 py-2 text-muted small">Sem notificações</div>';
            return;
          }
          rows.forEach(r => {
            const item = document.createElement('div');
            item.className = 'dropdown-item d-flex align-items-start';
            if (!r.lida) item.classList.add('bg-light');
            item.innerHTML = `
          <div class="flex-grow-1">
            <div class="small text-muted">${new Date(r.criado_em).toLocaleString()}</div>
            <div>${r.mensagem}</div>
          </div>
          <div class="ms-2">
            <button class="btn btn-sm btn-outline-secondary mark-read" data-id="${r.id}">OK</button>
          </div>
        `;
            list.appendChild(item);
          });

          list.querySelectorAll('.mark-read').forEach(btn => {
            btn.addEventListener('click', async (e) => {
              const id = e.currentTarget.dataset.id;
              const csrfLocal = csrf || document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');
              await fetch(`/notifications/mark-read/${id}`, {
                method: 'POST',
                credentials: 'same-origin',
                headers: csrfLocal ? { 'X-CSRF-Token': csrfLocal } : undefined
              });
              fetchCount();
              fetchList();
            });
          });
        } catch (e) {
          console.warn('Erro fetchList notifications:', e);
          list.innerHTML = '<div class="px-3 py-2 text-danger small">Erro de rede ao carregar notificações</div>';
        }
      }

      if (markAllBtn) {
        markAllBtn.addEventListener('click', async () => {
          await fetch('/notifications/mark-all-read', {
            method: 'POST',
            credentials: 'same-origin',
            headers: csrf ? { 'X-CSRF-Token': csrf } : undefined
          });
          fetchCount();
          fetchList();
        });
      }

      // Atualiza lista ao abrir o dropdown
      const notifToggle = document.getElementById('notifDropdown');
      if (notifToggle) {
        // Ao abrir o dropdown
        notifToggle.addEventListener('show.bs.dropdown', () => {
          fetchCount();
          fetchList();
        });
        // Clique no sino também força atualização
        notifToggle.addEventListener('click', () => {
          fetchCount();
          fetchList();
        });
      }

      if (typeof io !== 'undefined') {
        try {
          const socket = io();
          socket.on('connect', () => { });
          socket.on('newNotification', () => { fetchCount(); fetchList(); });
          socket.on('oilChangeNotification', () => { fetchCount(); fetchList(); });
          socket.on('manutencao:criada', () => { fetchCount(); fetchList(); });
          socket.on('manutencao:realizada', () => { fetchCount(); fetchList(); });
        } catch (e) {
          console.warn('Erro ao conectar socket.io para notifications:', e);
        }
      }

      // inicializa
      fetchCount();
      fetchList();
      // fallback: atualiza o badge a cada 30s mesmo sem eventos socket
      setInterval(fetchCount, 30000);
    });
  </script>

</body>

</html>