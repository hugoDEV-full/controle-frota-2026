  <style>
    /* Layout básico */
    body {
      margin: 0;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    .container-wrapper {
      display: flex;
      flex: 1;
      overflow: hidden;
    }

    /* ==========================
       SIDEBAR (MENU) MELHORADO
       - transições mais suaves
       - expansão por hover quando colapsado
       - animação de texto (fade/slide)
       - mantém todas as funcionalidades existentes
       ===========================*/

    .sidebar {
      background-color: #f8f9fa;
      border-right: 1px solid #dee2e6;
      overflow: hidden;

      /* largura padrão e animação suave */
      width: 250px;
      min-width: 80px;
      /* evita colapso extremo */

      /* usar transition em propriedades que não forçam layout drasticamente */
      transition: width 360ms cubic-bezier(.16, .84, .24, 1), box-shadow 300ms cubic-bezier(.2, .9, .2, 1), background-color 220ms cubic-bezier(.2, .9, .2, 1);
      will-change: width;
    }

    /* estado colapsado: largura menor e somente ícones visíveis */
    .sidebar.collapsed {
      width: 80px;
      box-shadow: none;
    }

    /* quando colapsado mas em hover, expandir temporariamente (melhor experiência UX) */
    .sidebar.collapsed:hover {
      width: 250px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.06);
      transition: width 360ms cubic-bezier(.16, .84, .24, 1), box-shadow 300ms cubic-bezier(.2, .9, .2, 1);
    }

    .sidebar ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .sidebar li {
      border-bottom: 1px solid #dee2e6;
    }

    /* estrutura do link: ícone + texto dentro de um flex para animar com facilidade */
    .sidebar a {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 13px 16px;
      color: #4c4d4e;
      text-decoration: none;

      /* suaves transições em background, color e padding */
      transition: background-color 180ms ease, color 160ms ease, padding 180ms ease;
      white-space: nowrap;
      /* evita quebra de texto */
      overflow: hidden;
    }

    /* hover mais pronunciado e suave */
    .sidebar a:hover,
    .sidebar a.active {
      background-color: #0d6efd;
      color: #fff;
    }

    /* ícone: centralizado quando menu colapsado */
    .sidebar i {
      font-size: 1.25rem;
      margin: 0;
      min-width: 30px;
      text-align: center;
      flex-shrink: 0;
      transition: transform 200ms ease;
    }

    /* texto do menu: animar com opacidade e translação em X para suavizar o aparecimento */
    .menu-text {
      display: inline-block;
      transform-origin: left center;
      transition: opacity 320ms cubic-bezier(.2, .9, .2, 1), transform 320ms cubic-bezier(.16, .84, .24, 1), max-width 260ms ease;
      opacity: 1;
      transform: translateX(0);
      max-width: 1000px;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* quando o sidebar está colapsado esconder o texto de forma animada (não usar display:none) */
    .sidebar.collapsed a .menu-text {
      opacity: 0;
      transform: translateX(-8px);
      max-width: 0;
      pointer-events: none;
      /* evita foco nas partes invisíveis */
    }

    /* ao passar o mouse sobre o sidebar colapsado, mostrar o texto com animação (consistente com .collapsed:hover width) */
    .sidebar.collapsed:hover a .menu-text {
      opacity: 1;
      transform: translateX(0);
      max-width: 1000px;
      pointer-events: auto;
    }

    /* ajuste visual para centralizar ícones quando o menu está colapsado */
    .sidebar.collapsed a {
      justify-content: flex-start;
    }

    /* quando expandido, alinhar ícone+texto à esquerda como antes */
    .sidebar:not(.collapsed) a {
      justify-content: flex-start;
    }

    /* foco acessível e borda suave */
    .sidebar a:focus {
      outline: none;
      box-shadow: inset 0 -2px 0 rgba(255, 255, 255, 0.04);
    }

    /* Conteúdo principal */
    main {
      flex: 1;
      padding: 1rem;
      overflow-y: auto;
    }

    /* Navbar */
    .navbar {
      flex-shrink: 0;
    }

    /* Rodapé */
    footer {
      background-color: #f8f9fa;
      padding: 1rem 0;
      text-align: center;
      border-top: 1px solid #dee2e6;
      flex-shrink: 0;
    }

    #scrollBtn {
      position: fixed;
      bottom: 20px;
      right: 20px;
      display: none;
      border-radius: 50%;
      width: 50px;
      height: 50px;
      font-size: 24px;
      text-align: center;
      box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);
    }

    /* Toggle button icon rotation (suave) */
    #toggleSidebar i {
      transition: transform 220ms ease;
    }

    /* quando o sidebar NÃO tiver a classe collapsed, rotaciona levemente o ícone para indicar estado */
    #sidebar:not(.collapsed)+main~#toggleSidebar i {
      transform: rotate(0deg);
    }
  </style>
