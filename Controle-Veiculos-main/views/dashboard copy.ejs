        // Versão atualizada — prioriza nome_marca / nome_modelo salvos no backend
async function loadDevicesDebug() {
  try {
    console.clear();
    console.log('> loadDevicesDebug: iniciando...');

    spinner.classList.remove('d-none');

    // 1) buscar dispositivos do backend
    console.log('> fetch /devices-com-veiculo ...');
    const res = await fetch('/devices-com-veiculo');
    console.log('> status /devices-com-veiculo:', res.status, res.statusText);
    if (!res.ok) {
      const text = await res.text().catch(() => null);
      console.error('> Erro na requisição /devices-com-veiculo:', res.status, text);
      throw new Error('Erro na requisição /devices-com-veiculo');
    }

    const devs = await res.json();
    console.log('> dados recebidos do backend (devs):', devs);
    console.log('> total devices retornados:', Array.isArray(devs) ? devs.length : 'não é array');

    // mostrar cada device com tipos dos campos marca/modelo
    (devs || []).forEach((d, i) => {
      console.log(`> device[${i}] id=${d.id} name=${d.name} placa=${d.placa} marca=(${typeof d.marca}) ${d.marca} nome_marca=(${typeof d.nome_marca}) ${d.nome_marca} modelo=(${typeof d.modelo}) ${d.modelo} nome_modelo=(${typeof d.nome_modelo}) ${d.nome_modelo}`);
    });

    const FIPE_BASE = 'https://parallelum.com.br/fipe/api/v1';

    // Determinar se precisamos de traduções FIPE:
    // precisamos quando backend NÃO retornou nome_marca/nome_modelo e recebemos códigos numéricos
    const marcasParaBuscar = new Set();
    let precisaCarregarMarcasFIPE = false;
    devs.forEach(d => {
      const hasNomeMarca = d.nome_marca && String(d.nome_marca).trim() !== '';
      const hasNomeModelo = d.nome_modelo && String(d.nome_modelo).trim() !== '';
      const marcaIsCode = d.marca && /^\d+$/.test(String(d.marca));
      const modeloIsCode = d.modelo && /^\d+$/.test(String(d.modelo));

      // se não temos nome_marca e marca é código, precisamos traduzir essa marca
      if (!hasNomeMarca && marcaIsCode) {
        marcasParaBuscar.add(String(d.marca));
        precisaCarregarMarcasFIPE = true;
      }

      // se não temos nome_modelo e modelo é código, garantimos que a marca numérica esteja na lista
      if (!hasNomeModelo && modeloIsCode) {
        // se marca também for código, adiciona; senão tentaremos mapear pelo que temos
        if (marcaIsCode) marcasParaBuscar.add(String(d.marca));
        precisaCarregarMarcasFIPE = true;
      }
    });

    console.log('> marcas numéricas para buscar (se necessário):', Array.from(marcasParaBuscar));

    let marcaCodeToNome = {};
    // 2) buscar FIPE marcas apenas se necessário
    if (precisaCarregarMarcasFIPE) {
      try {
        console.log('> fetch FIPE marcas (necessário) ...');
        const fipeMarcasResp = await fetch(`${FIPE_BASE}/carros/marcas`);
        console.log('> status FIPE marcas:', fipeMarcasResp.status);
        if (fipeMarcasResp.ok) {
          const fipeMarcas = await fipeMarcasResp.json();
          (fipeMarcas || []).forEach(m => {
            if (m && (m.codigo !== undefined || m.nome !== undefined)) {
              marcaCodeToNome[String(m.codigo)] = m.nome || m.name || null;
            }
          });
        } else {
          console.warn('> FIPE marcas retornou status não-ok:', fipeMarcasResp.status);
        }
      } catch (e) {
        console.warn('> Erro ao buscar FIPE marcas:', e);
      }
    } else {
      console.log('> salto fetch FIPE marcas (não necessário)');
    }
    console.log('> quantidade marcas FIPE carregadas:', Object.keys(marcaCodeToNome).length);
    console.log('> amostra marcaCodeToNome (primeiros 10):', Object.entries(marcaCodeToNome).slice(0, 10));

    // 3) buscar modelos apenas para as marcas necessárias (quando precisarmos traduzir modelos por código)
    const marcaCodigoParaModelosMap = {};
    if (Object.keys(marcaCodeToNome).length && marcasParaBuscar.size) {
      console.log('> buscando modelos FIPE apenas para marcas necessárias...');
      await Promise.all(Array.from(marcasParaBuscar).map(async marcaCode => {
        try {
          console.log(`> fetch modelos para marca ${marcaCode} -> ${marcaCodeToNome[marcaCode] || 'NOME_DESCONHECIDO'}`);
          const resp = await fetch(`${FIPE_BASE}/carros/marcas/${marcaCode}/modelos`);
          console.log(`> status modelos marca ${marcaCode}:`, resp.status);
          if (!resp.ok) {
            console.warn('> resposta não-ok para marca', marcaCode);
            return;
          }
          const data = await resp.json();
          // endpoint devolve {modelos: [...], anos: ...}
          const modelosArr = Array.isArray(data) ? data : (Array.isArray(data.modelos) ? data.modelos : []);
          const modelosMap = {};
          modelosArr.forEach(mo => {
            if (mo && (mo.codigo !== undefined)) modelosMap[String(mo.codigo)] = mo.nome || mo.name || mo.modelName || null;
          });
          marcaCodigoParaModelosMap[marcaCode] = modelosMap;
          console.log(`> carregados ${modelosArr.length} modelos para marca ${marcaCode}`);
        } catch (e) {
          console.warn('> Erro ao buscar modelos FIPE para marca', marcaCode, e);
        }
      }));
    } else {
      console.log('> salto fetch modelos FIPE (nenhuma marca necessária)');
    }
    console.log('> marcas para as quais carregamos modelos:', Object.keys(marcaCodigoParaModelosMap));

    // 4) resolver marca + modelo priorizando nome_marca/nome_modelo do backend
    const resolvedDevs = devs.map(d => {
      // se backend já forneceu nome_marca/nome_modelo, usa diretamente (prioridade)
      let marcaResolvida = (d.nome_marca && String(d.nome_marca).trim() !== '') ? String(d.nome_marca).trim() : null;
      let modeloResolvido = (d.nome_modelo && String(d.nome_modelo).trim() !== '') ? String(d.nome_modelo).trim() : null;

      // se não temos nome_marca, tentar traduzir a partir de d.marca
      if (!marcaResolvida) {
        if (d.marca && /^\d+$/.test(String(d.marca))) {
          marcaResolvida = marcaCodeToNome[String(d.marca)] || null;
        } else if (d.marca) {
          // d.marca pode já conter um nome (fallback)
          marcaResolvida = String(d.marca).trim();
        }
      }

      // se não temos nome_modelo, tentar traduzir a partir de d.modelo
      if (!modeloResolvido) {
        if (d.modelo && /^\d+$/.test(String(d.modelo))) {
          // se temos mapa de modelos para a marca (e a marca é código), usa
          const marcaCode = (d.marca && /^\d+$/.test(String(d.marca))) ? String(d.marca) : null;
          if (marcaCode && marcaCodigoParaModelosMap[marcaCode]) {
            modeloResolvido = marcaCodigoParaModelosMap[marcaCode][String(d.modelo)] || null;
          } else {
            // tentativa: buscar em qualquer marca carregada que contenha esse código
            for (const [mCod, modelosMap] of Object.entries(marcaCodigoParaModelosMap)) {
              if (modelosMap && modelosMap[String(d.modelo)]) {
                modeloResolvido = modelosMap[String(d.modelo)];
                // se marcaResolvida ainda for nula, tenta preencher com o nome da marca encontrada
                if (!marcaResolvida) marcaResolvida = marcaCodeToNome[mCod] || marcaResolvida;
                break;
              }
            }
          }
        } else if (d.modelo) {
          // d.modelo pode já ser um nome
          modeloResolvido = String(d.modelo).trim();
        }
      }

      if (!marcaResolvida) marcaResolvida = 'Desconhecida';
      if (!modeloResolvido) modeloResolvido = 'Desconhecido';

      return { ...d, marcaResolvida, modeloResolvido };
    });

    console.log('> resolvedDevs (amostra):', resolvedDevs.slice(0, 20));
    resolvedDevs.forEach((d, i) => {
      if (d.marcaResolvida === 'Desconhecida') {
        console.warn(`> device[${i}] id=${d.id} marcaResolvida=DESCONHECIDA modelo=${d.modelo}`);
      }
    });

    // 5) popular o select (com logs)
    resolvedDevs.sort((a, b) => b.id - a.id);
    deviceSelect.innerHTML = '';
    resolvedDevs.forEach(d => {
      const opt = document.createElement('option');
      opt.value = d.id;
      opt.textContent = `${d.name} — Placa: ${d.placa || '—'} | Marca: ${d.marcaResolvida} | Modelo: ${d.modeloResolvido}`;
      deviceSelect.append(opt);
    });

    if (resolvedDevs.length) deviceSelect.dispatchEvent(new Event('change'));

    console.log('> loadDevicesDebug: finalizado com sucesso.');

  } catch (err) {
    deviceSelect.innerHTML = '<option>Erro ao carregar</option>';
    console.error('> loadDevicesDebug: erro geral:', err);
  } finally {
    spinner.classList.add('d-none');
  }
}

// execute
loadDevicesDebug();





        // Marcador principal (icone com popupAnchor ajustado para aparecer acima)
        const vehicleIcon = L.divIcon({
          html: '<i class="fas fa-car fa-2x"></i>',
          className: 'vehicle-marker-icon',
          iconSize: [32, 32],
          iconAnchor: [16, 16],
          popupAnchor: [0, -5] // empurra o popup para cima do ícone
        });

        let vehicleMarker = L.marker(map.getCenter(), { icon: vehicleIcon })
          .addTo(map);

        // bindPopup com offset extra por segurança (mantém acima em diferentes zooms)
        vehicleMarker.bindPopup('🚗 Veículo', { autoPan: true, closeButton: true, offset: L.point(0, -28) });

        // Variável para controlar se o popup foi fechado manualmente
        let popupManuallyClosed = false;

        // camadas e helpers
        const allVehicleLayer = L.featureGroup().addTo(map);
        const allVehicleMarkers = {};
        const colors = ['#e74c3c', '#3498db', '#27ae60', '#f39c12', '#8e44ad', '#c0392b', '#2c3e50'];
        let autoPan = true, socket;

        // listener do select (mantive seu fluxo)
        deviceSelect.addEventListener('change', () => {
          const devId = deviceSelect.value;
          if (!devId) return;
          autoPan = true;

          // desconecta socket anterior com segurança
          if (socket) {
            try { socket.emit('unsubscribeFromDevice', socket.deviceId || devId); } catch (e) {/* ignore */ }
            socket.disconnect();
            socket = null;
          }

          vehicleMarker.setLatLng(map.getCenter());

          // Configura eventos de clique no marcador do veículo
          vehicleMarker.off('click'); // Remove eventos anteriores
          vehicleMarker.on('click', () => {
            popupManuallyClosed = false;
            vehicleMarker.togglePopup();

            // Adiciona funcionalidade de "voltar ao veículo" ao clicar no carro
            // Mesma ação do botão de mira (crosshairs)
            const p = vehicleMarker.getLatLng();
            map.flyTo(p, 16, { animate: true, duration: 0.5 });
          });

          // Quando o usuário fecha o popup com o X, marca que foi fechado manualmente
          vehicleMarker.off('popupclose'); // Remove eventos anteriores
          vehicleMarker.on('popupclose', () => {
            popupManuallyClosed = true;
          });

          // Histórico único
          fetch(`/gps-history?device=${devId}`)
            .then(r => r.ok ? r.json() : Promise.reject())
            .then(hist => {
              if (!hist.length) return;
              const last = hist.pop();
              const dt = new Date(last.datahora_recebido);
              vehicleMarker
                .setLatLng([+last.latitude, +last.longitude])
                .setPopupContent(
                  `<i class="fas fa-car"></i> ${deviceSelect.selectedOptions[0].text}<br>` +
                  `<small class="text-muted">${dt.toLocaleDateString('pt-BR')} ${dt.toLocaleTimeString('pt-BR')}</small>`
                );
              if (autoPan) map.panTo([+last.latitude, +last.longitude], { animate: true, duration: 0.5 });
              // não abre o popup automaticamente — só abre ao clicar no marker
            })
            .catch(() => console.error('Erro histórico'));

          // Socket.IO real-time
          socket = io();
          socket.deviceId = devId;
          let prevLat = null, prevLng = null, prevTime = null;

          socket.on('connect', () => socket.emit('subscribeToDevice', devId));
          socket.on('locationUpdate', pt => {
            const lat = +pt.latitude,
              lng = +pt.longitude,
              currTime = new Date(pt.datahora_recebido);

            let popupHtml = `<i class="fas fa-car"></i> ${deviceSelect.selectedOptions[0].text}<br>` +
              `<small class="text-muted">${currTime.toLocaleDateString('pt-BR')} ${currTime.toLocaleTimeString('pt-BR')}</small>`;

            // calcula velocidade se houver ponto anterior
            if (prevTime !== null) {
              const dist = L.latLng(prevLat, prevLng).distanceTo(L.latLng(lat, lng)); // metros
              const dtSec = (currTime - prevTime) / 1000;                             // s
              const speedKmh = dtSec > 0 ? (dist / dtSec) * 3.6 : 0;                       // km/h
              popupHtml += `<br><strong>Velocidade:</strong> ${speedKmh.toFixed(1)} km/h`;
            }

            // atualiza posição e conteúdo do popup (sem forçar abertura)
            vehicleMarker
              .setLatLng([lat, lng])
              .setPopupContent(popupHtml);

            // se o popup estiver aberto E não foi fechado manualmente, mantém aberto (atualiza visual)
            if (vehicleMarker.isPopupOpen() && !popupManuallyClosed) {
              // reabrir para aplicar conteúdo atualizado (se necessário)
              vehicleMarker.getPopup().setContent(popupHtml);
              // garantir que continue aberto:
              // OBS: não chamar openPopup() se o usuário tiver fechado manualmente (popupManuallyClosed === true)
            }

            // atualiza prev para próxima
            prevLat = lat;
            prevLng = lng;
            prevTime = currTime;

            if (autoPan) {
              map.panTo([lat, lng], { animate: true, duration: 0.5 });
            }
          });
        });


        // "Mostrar Todos"
        document.getElementById('btnMostrarTodos').addEventListener('click', () => {
          if (map.hasLayer(vehicleMarker)) map.removeLayer(vehicleMarker);
          allVehicleLayer.clearLayers();
          Object.keys(allVehicleMarkers).forEach(id => delete allVehicleMarkers[id]);

          const opts = Array.from(deviceSelect.options).filter(o => o.value);
          Promise.all(opts.map((o, idx) =>
            fetch(`/gps-history?device=${o.value}`)
              .then(r => r.ok ? r.json() : Promise.reject())
              .then(h => h.length ? {
                id: o.value,
                lat: +h.pop().latitude,
                lng: +h.pop().longitude,
                dt: new Date(h.pop().datahora_recebido),
                color: colors[idx % colors.length],
                deviceText: o.textContent
              } : null)
              .catch(() => null)
          )).then(list => {
            list.forEach(d => {
              if (!d) return;
              const mk = L.marker([d.lat, d.lng], {
                icon: L.divIcon({
                  html: `<i class="fas fa-car fa-lg" style="color:${d.color}"></i>`,
                  className: 'vehicle-marker-icon',
                  iconSize: [24, 24], iconAnchor: [12, 12], popupAnchor: [0, -12]
                })
              }).bindPopup(
                `${d.deviceText}<br>Atualizado em: ${d.dt.toLocaleDateString('pt-BR')} ${d.dt.toLocaleTimeString('pt-BR')}`
              );
              allVehicleLayer.addLayer(mk);
              allVehicleMarkers[d.id] = mk;
            });
          });
        });

        // Força redraw
        setTimeout(() => map.invalidateSize(), 500);
      });
    </script>











    <script>
      function updateDateTime() {
        const now = new Date();
        const options = {
          weekday: 'long',
          year: 'numeric',
          month: 'long',
          day: 'numeric',
          hour: '2-digit',
          minute: '2-digit',
          second: '2-digit'
        };
        document.getElementById('datetime').innerText = now.toLocaleDateString('pt-BR', options);
      }
      // Atualiza a cada segundo
      setInterval(updateDateTime, 1000);
      updateDateTime();
    </script>


    <script>
      document.addEventListener('DOMContentLoaded', () => {
        let elapsed, remaining;
        let localTimer, syncInterval;

        function updateDOM() {
          document.getElementById('sess-elapsed').textContent =
            `${elapsed.minutes}m ${elapsed.seconds}s`;
          document.getElementById('sess-remaining').textContent =
            `${remaining.minutes}m ${remaining.seconds}s`;
        }

        function tickLocal() {
          elapsed.seconds++;
          if (elapsed.seconds === 60) {
            elapsed.minutes++;
            elapsed.seconds = 0;
          }
          if (remaining.minutes > 0 || remaining.seconds > 0) {
            remaining.seconds--;
            if (remaining.seconds < 0) {
              remaining.minutes--;
              remaining.seconds = 59;
            }
          }
          updateDOM();
        }

        async function syncSession() {
          try {
            const res = await fetch('/session-info/json');
            if (!res.ok) throw new Error(res.status);
            const data = await res.json();
            elapsed = data.elapsed;
            remaining = data.remaining;
            updateDOM();
          } catch (err) {
            console.error('Erro ao buscar sessão:', err);
          }
        }

        (async () => {
          await syncSession();                          // 1. busca inicial
          localTimer = setInterval(tickLocal, 1000); // 2. contagem local
          syncInterval = setInterval(syncSession, 10000); // 3. sincroniza a cada 10s
        })();

        window.addEventListener('beforeunload', () => {
          clearInterval(localTimer);
          clearInterval(syncInterval);
        });
      });
    </script>