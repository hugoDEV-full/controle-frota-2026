  <!-- Scripts -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
  <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
  <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

  <script>
    // Initialize DataTables
    $(document).ready(function() {
      $('#vehiclesTable').DataTable({
        pageLength: 5,
        language: {
          search: "Buscar:",
          lengthMenu: "Mostrar _MENU_ registros",
          info: "Mostrando _START_ a _END_ de _TOTAL_ registros",
          paginate: {
            first: "Primeiro",
            last: "Último",
            next: "Próximo",
            previous: "Anterior"
          }
        }
      });

      $('#reportsTable').DataTable({
        pageLength: 5,
        searching: false,
        paging: false,
        info: false
      });
    });

    // Initialize Hero Map
    let heroMap, gpsMap;
    let gpsSimulation = true;
    let gpsVehicles = [];
    let gpsMarkers = {};
    let gpsRoutes = {};

    // Initialize maps when page loads
    document.addEventListener('DOMContentLoaded', function() {
      initializeHeroMap();
      initializeGpsMap();
    });

    function initializeHeroMap() {
      heroMap = L.map('heroMap').setView([-23.55, -46.63], 12);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors'
      }).addTo(heroMap);

      // Add sample markers
      const locations = [
        {lat: -23.5505, lng: -46.6333, name: "Fiesta - ABC-1234"},
        {lat: -23.5480, lng: -46.6310, name: "Onix - DEF-5678"},
        {lat: -23.5520, lng: -46.6340, name: "Palio - GHI-9012"}
      ];

      locations.forEach(loc => {
        L.marker([loc.lat, loc.lng])
          .addTo(heroMap)
          .bindPopup(loc.name);
      });
    }

    function initializeGpsMap() {
      gpsMap = L.map('demoGpsMap').setView([-23.55, -46.63], 12);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors'
      }).addTo(gpsMap);

      // Initialize demo vehicles
      gpsVehicles = [
        { id: 'DEMO001', name: 'Fiesta', lat: -23.5505, lng: -46.6333, color: '#ff0000', speed: 0.00002, direction: 1 },
        { id: 'DEMO002', name: 'Onix', lat: -23.5480, lng: -46.6310, color: '#00ff00', speed: 0.000025, direction: -1 },
        { id: 'DEMO003', name: 'Palio', lat: -23.5520, lng: -46.6340, color: '#0000ff', speed: 0.000022, direction: 1 }
      ];

      // Create markers
      gpsVehicles.forEach(vehicle => {
        const marker = L.marker([vehicle.lat, vehicle.lng], {
          icon: L.divIcon({
            html: `<div style="background-color: ${vehicle.color}; color: white; border-radius: 50%; width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; font-weight: bold; border: 2px solid white;">🚗</div>`,
            className: 'demo-vehicle-marker',
            iconSize: [30, 30],
            iconAnchor: [15, 15]
          })
        }).addTo(gpsMap);

        marker.bindPopup(`<strong>${vehicle.name}</strong><br>Velocidade: ${(vehicle.speed * 100000).toFixed(1)} km/h`);
        gpsMarkers[vehicle.id] = marker;
        gpsRoutes[vehicle.id] = [];
      });

      // Start simulation
      startGpsSimulation();
    }

    function startGpsSimulation() {
      setInterval(() => {
        if (!gpsSimulation) return;

        gpsVehicles.forEach(vehicle => {
          // Update position
          vehicle.lat += vehicle.speed * vehicle.direction;
          vehicle.lng += vehicle.speed * vehicle.direction * 0.8;

          // Change direction randomly
          if (Math.random() < 0.05) {
            vehicle.direction *= -1;
          }

          // Keep within bounds
          if (vehicle.lat < -23.60 || vehicle.lat > -23.50) {
            vehicle.direction *= -1;
          }
          if (vehicle.lng < -46.70 || vehicle.lng > -46.60) {
            vehicle.direction *= -1;
          }

          // Update marker
          const marker = gpsMarkers[vehicle.id];
          marker.setLatLng([vehicle.lat, vehicle.lng]);

          // Add to route
          gpsRoutes[vehicle.id].push([vehicle.lat, vehicle.lng]);
          if (gpsRoutes[vehicle.id].length > 20) {
            gpsRoutes[vehicle.id].shift();
          }

          // Draw route
          if (gpsRoutes[vehicle.id].length > 1) {
            if (window[`demoRoute_${vehicle.id}`]) {
              gpsMap.removeLayer(window[`demoRoute_${vehicle.id}`]);
            }

            const polyline = L.polyline(gpsRoutes[vehicle.id], {
              color: vehicle.color,
              weight: 3,
              opacity: 0.7
            }).addTo(gpsMap);

            window[`demoRoute_${vehicle.id}`] = polyline;
          }
        });
      }, 3000);
    }

    function toggleGpsSimulation() {
      gpsSimulation = !gpsSimulation;
    }

    function clearGpsRoutes() {
      Object.keys(window).forEach(key => {
        if (key.startsWith('demoRoute_')) {
          gpsMap.removeLayer(window[key]);
          delete window[key];
        }
      });
      
      Object.keys(gpsRoutes).forEach(key => {
        gpsRoutes[key] = [];
      });
    }

    function showRouteDemo() {
      alert('Funcionalidade: Esta ferramenta exibe rotas detalhadas com mapas interativos, coordenadas GPS e histórico completo das viagens realizadas pela frota.');
    }

    function showReportMap(startLat, startLng, endLat, endLng) {
      alert(`Mapa da Rota:\nInício: ${startLat}, ${startLng}\nFim: ${endLat}, ${endLng}\n\nNo sistema, você visualiza mapas interativos com marcadores precisos e rotas traçadas para cada viagem.`);
    }

    function startDemo() {
      alert('Tour do Sistema:\n\n1. Veículos - Gestão completa da frota\n2. GPS - Rastreamento em tempo real\n3. Rotas - Controle de viagens\n4. Relatórios - Análises detalhadas\n5. Manutenção - Serviços programados\n\nNavegue pelas abas para conhecer cada recurso!');
    }

    function contactSales() {
      alert('Contato de Vendas:\n\n📧 E-mail: vendas@controlefrota.com\n📞 Telefone: (11) 3000-0000\n💬 WhatsApp: (11) 90000-0000\n\nHorário: Seg-Sex, 8h-18h');
    }
  </script>
