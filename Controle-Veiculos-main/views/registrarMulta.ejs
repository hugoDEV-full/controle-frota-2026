<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= title %>
  </title>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <!-- Bootstrap icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/styles.css">
</head>

<body>
  <div class="container mt-4">
    <h1><i class="bi bi-exclamation-triangle-fill text-danger me-2"></i>Registrar Multa</h1>

    <% if (mensagemErro) { %>
      <div class="alert alert-warning">
        <%= mensagemErro %>
      </div>
      <% } %>

        <form action="/registrar-multa/<%= veiculo.id %>" method="POST" onsubmit="return confirmarSubmit();">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="orgao_autuador" class="form-label">
                Órgão Autuador *
                <i class="bi bi-info-circle ms-1" tabindex="0" role="button" data-bs-toggle="tooltip"
                  data-bs-placement="top" title="Nome do órgão que emitiu a autuação (ex.: DETRAN, PRF)."></i>
              </label>
              <input type="text" class="form-control" id="orgao_autuador" name="orgao_autuador"
                value="<%= formValues.orgao_autuador || '' %>" required>
            </div>

            <div class="col-md-6 mb-3">
              <label for="numero_auto" class="form-label">
                Número do Auto *
                <i class="bi bi-info-circle ms-1" tabindex="0" role="button" data-bs-toggle="tooltip"
                  data-bs-placement="top"
                  title="Número do auto de infração (constante no documento). Preencha exatamente como consta no auto."></i>
              </label>
              <input type="text" class="form-control" id="numero_auto" name="numero_auto"
                value="<%= formValues.numero_auto || '' %>" required>
            </div>
          </div>

          <div class="row">
            <div class="col-md-4 mb-3">
              <label for="veiculo" class="form-label">
                Veículo
                <i class="bi bi-info-circle ms-1" tabindex="0" role="button" data-bs-toggle="tooltip"
                  data-bs-placement="top" title="Veículo associado ao cadastro. Campo somente leitura."></i>
              </label>
              <input type="text" class="form-control" id="veiculo"
                value="<%= veiculo.display_name || ((veiculo.nome_marca || veiculo.marca || '') + ((veiculo.nome_modelo || veiculo.modelo) ? ' ' + (veiculo.nome_modelo || veiculo.modelo) : '')) %>"
                readonly>

            </div>
            <div class="col-md-4 mb-3">
              <label for="placa" class="form-label">
                Placa
                <i class="bi bi-info-circle ms-1" tabindex="0" role="button" data-bs-toggle="tooltip"
                  data-bs-placement="top"
                  title="Placa do veículo. Normalmente preenchida automaticamente a partir do cadastro do veículo."></i>
              </label>
              <input type="text" class="form-control" id="placa" name="placa"
                value="<%= formValues.placa || veiculo.placa || '' %>" readonly>
            </div>
            <div class="col-md-4 mb-3">
              <label for="data_multa" class="form-label">
                Data e Hora da Infração *
                <i class="bi bi-info-circle ms-1" tabindex="0" role="button" data-bs-toggle="tooltip"
                  data-bs-placement="top"
                  title="Selecione a data e hora exatas em que a infração ocorreu. Formato local do navegador."></i>
              </label>
              <input type="datetime-local" class="form-control" id="data_multa" name="data_multa"
                value="<%= formValues.data_multa || '' %>" required>
            </div>
          </div>

          <div class="mb-3">
            <label for="multa" class="form-label">
              Descrição da Multa / Observações *
              <i class="bi bi-info-circle ms-1" tabindex="0" role="button" data-bs-toggle="tooltip"
                data-bs-placement="top"
                title="Descrição breve do motivo da autuação (ex.: excesso de velocidade registrado por radar)."></i>
            </label>
            <input type="text" class="form-control" id="multa" name="multa" value="<%= formValues.multa || '' %>"
              required>
          </div>

          <div class="row">
            <div class="col-md-4 mb-3">
              <label for="condutor" class="form-label">
                Condutor
                <i class="bi bi-info-circle ms-1" tabindex="0" role="button" data-bs-toggle="tooltip"
                  data-bs-placement="top"
                  title="Nome do condutor no momento da infração. Se vazio, tentaremos associar o motorista pelo uso registrado do veículo."></i>
              </label>
              <input type="text" class="form-control" id="condutor" name="condutor"
                value="<%= formValues.condutor || '' %>">
              <div class="form-text">Se não preenchido, tentaremos associar pelo uso do veículo.</div>
            </div>
            <div class="col-md-4 mb-3">
              <label for="infrator" class="form-label">
                Infrator
                <i class="bi bi-info-circle ms-1" tabindex="0" role="button" data-bs-toggle="tooltip"
                  data-bs-placement="top" title="Pessoa considerada infratora (pode ser o mesmo que o condutor)."></i>
              </label>
              <input type="text" class="form-control" id="infrator" name="infrator"
                value="<%= formValues.infrator || '' %>">
            </div>
            <div class="col-md-4 mb-3">
              <label for="local_infracao" class="form-label">
                Local da Infração
                <i class="bi bi-info-circle ms-1" tabindex="0" role="button" data-bs-toggle="tooltip"
                  data-bs-placement="top" title="Informe o local conforme consta no auto (rua, km, cidade)."></i>
              </label>
              <input type="text" class="form-control" id="local_infracao" name="local_infracao"
                value="<%= formValues.local_infracao || '' %>">
            </div>
          </div>

          <div class="row">
            <div class="col-md-4 mb-3">
              <label for="tipo_infracao_id" class="form-label">
                Tipo da Infração
                <i class="bi bi-info-circle ms-1" tabindex="0" role="button" data-bs-toggle="tooltip"
                  data-bs-placement="top"
                  title="Selecione o tipo de infração a partir da lista. Se não encontrar, peça para adicionar na tabela de tipos."></i>
              </label>
              <select class="form-select" id="tipo_infracao_id" name="tipo_infracao_id">
                <option value="">-- selecione --</option>
                <% tipos_infracoes.forEach(tipo=> { %>
                  <option value="<%= tipo.id %>" <%=formValues.tipo_infracao_id==tipo.id ? 'selected' : '' %>><%=
                      tipo.codigo %> - <%= tipo.descricao %>
                  </option>
                  <% }) %>
              </select>
            </div>

            <div class="col-md-2 mb-3">
              <label for="limite_via" class="form-label">
                Limite da Via
                <i class="bi bi-info-circle ms-1" tabindex="0" role="button" data-bs-toggle="tooltip"
                  data-bs-placement="top" title="Velocidade limite regulamentada (em km/h) quando aplicável."></i>
              </label>
              <input type="number" step="0.01" class="form-control" id="limite_via" name="limite_via"
                value="<%= formValues.limite_via || '' %>">
            </div>

            <div class="col-md-2 mb-3">
              <label for="medicao_realizada" class="form-label">
                Medição Realizada
                <i class="bi bi-info-circle ms-1" tabindex="0" role="button" data-bs-toggle="tooltip"
                  data-bs-placement="top" title="Valor medido (por exemplo, velocidade registrada pelo radar)."></i>
              </label>
              <input type="number" step="0.01" class="form-control" id="medicao_realizada" name="medicao_realizada"
                value="<%= formValues.medicao_realizada || '' %>">
            </div>

            <div class="col-md-2 mb-3">
              <label for="valor_considerado" class="form-label">
                Valor Considerado
                <i class="bi bi-info-circle ms-1" tabindex="0" role="button" data-bs-toggle="tooltip"
                  data-bs-placement="top" title="Valor base usado para cálculo (se houver uma regra específica)."></i>
              </label>
              <input type="number" step="0.01" class="form-control" id="valor_considerado" name="valor_considerado"
                value="<%= formValues.valor_considerado || '' %>">
            </div>

            <div class="col-md-2 mb-3">
              <label for="valor" class="form-label">
                Valor (R$) *
                <i class="bi bi-info-circle ms-1" tabindex="0" role="button" data-bs-toggle="tooltip"
                  data-bs-placement="top"
                  title="Valor total da multa (sem desconto). Use ponto ou vírgula como separador decimal."></i>
              </label>
              <input type="number" step="0.01" class="form-control" id="valor" name="valor"
                value="<%= formValues.valor || '' %>" required>
            </div>
          </div>

          <div class="row align-items-end">
            <div class="col-md-3 mb-3">
              <label for="desconto_percentual" class="form-label">
                Desconto (%)
                <i class="bi bi-info-circle ms-1" tabindex="0" role="button" data-bs-toggle="tooltip"
                  data-bs-placement="top"
                  title="Percentual de desconto (por exemplo, desconto por pagamento antecipado). Informe apenas números."></i>
              </label>
              <input type="number" step="0.01" class="form-control" id="desconto_percentual" name="desconto_percentual"
                value="<%= formValues.desconto_percentual || '0.00' %>">
            </div>

            <div class="col-md-3 mb-3">
              <label for="valor_com_desconto" class="form-label">
                Valor com Desconto (R$)
                <i class="bi bi-info-circle ms-1" tabindex="0" role="button" data-bs-toggle="tooltip"
                  data-bs-placement="top"
                  title="Valor calculado automaticamente conforme o desconto informado. Campo somente leitura."></i>
              </label>
              <input type="text" class="form-control" id="valor_com_desconto" name="valor_com_desconto" readonly
                value="<%= formValues.valor_com_desconto || '' %>">
            </div>

            <div class="col-md-3 mb-3">
              <label for="data_vencimento" class="form-label">
                Data do Vencimento
                <i class="bi bi-info-circle ms-1" tabindex="0" role="button" data-bs-toggle="tooltip"
                  data-bs-placement="top"
                  title="Data limite para pagamento sem acréscimos. Use o calendário para selecionar."></i>
              </label>
              <input type="date" class="form-control" id="data_vencimento" name="data_vencimento"
                value="<%= formValues.data_vencimento || '' %>">
            </div>

            <div class="col-md-3 mb-3">
              <label for="data_recurso" class="form-label">
                Data para Interposição de Recurso
                <i class="bi bi-info-circle ms-1" tabindex="0" role="button" data-bs-toggle="tooltip"
                  data-bs-placement="top" title="Data limite para apresentação de recurso (se aplicável)."></i>
              </label>
              <input type="date" class="form-control" id="data_recurso" name="data_recurso"
                value="<%= formValues.data_recurso || '' %>">
            </div>
          </div>

          <div class="mt-3">
            <button type="submit" class="btn btn-danger" data-bs-toggle="tooltip" title="Salvar multa no sistema">
              <i class="bi bi-save-fill me-1"></i>Registrar Multa
            </button>
            <a href="/relatorio-multas" class="btn btn-secondary" data-bs-toggle="tooltip"
              title="Ver todas as multas cadastradas">
              <i class="bi bi-file-earmark-text me-1"></i>Ver Relatório de Multas
            </a>
            <a href="/" class="btn btn-secondary" data-bs-toggle="tooltip" title="Voltar para a página inicial">
              <i class="bi bi-arrow-left me-1"></i>Voltar para a Página Inicial
            </a>
          </div>
        </form>
  </div>

  <!-- Bootstrap JS bundle -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    // Inicializa tooltips do Bootstrap (para mouse e teclado)
    document.addEventListener('DOMContentLoaded', function () {
      var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
      tooltipTriggerList.forEach(function (tooltipTriggerEl) {
        new bootstrap.Tooltip(tooltipTriggerEl, {
          trigger: 'hover focus',
          boundary: 'window'
        });
      });
    });

    // calcula o valor com desconto em tempo real
    function calcularValorComDesconto() {
      const valorEl = document.getElementById('valor');
      const descontoEl = document.getElementById('desconto_percentual');
      const outputEl = document.getElementById('valor_com_desconto');

      const valor = parseFloat((valorEl && valorEl.value) ? String(valorEl.value).replace(',', '.') : '0');
      const desconto = parseFloat((descontoEl && descontoEl.value) ? String(descontoEl.value).replace(',', '.') : '0');
      if (isNaN(valor) || isNaN(desconto)) {
        outputEl.value = '';
        return;
      }
      const result = (valor * (1 - (desconto / 100)));
      outputEl.value = result.toFixed(2);
    }

    var valorInput = document.getElementById('valor');
    var descontoInput = document.getElementById('desconto_percentual');
    if (valorInput) valorInput.addEventListener('input', calcularValorComDesconto);
    if (descontoInput) descontoInput.addEventListener('input', calcularValorComDesconto);

    // Confirm antes de enviar
    function confirmarSubmit() {
      return confirm('Você revisou as informações? Deseja realmente confirmar e registrar a multa?');
    }

    // Faz cálculo inicial se o form vier com valores
    window.addEventListener('load', calcularValorComDesconto);
  </script>
</body>

</html>